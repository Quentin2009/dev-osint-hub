---
// Importation du CSS Tailwind
import '../styles/global.css';

// Importation des données
import toolsData from '../data/tools.json';

// Fonction de nettoyage pour supprimer les artefacts Markdown [↑](#-table-of-contents)
const sanitizeText = (txt: string) => {
  if (!txt) return '';
  return txt
    .replace(/\[↑\]\(#-table-of-contents\)/gi, '')
    .replace(/\[↑\]\(#.*?\)/gi, '')
    .replace(/\[\^.*?\]/g, '')
    .replace(/\[(.*?)\]\(.*?\)/g, '$1')
    .trim();
};

// Enrichissement et nettoyage des données côté serveur Astro
const enrichedTools = toolsData.map((tool: any, index: number) => {
  const rawDesc = tool.description || tool.safeDesc || 'Pas de description disponible.';
  return {
    id: tool.id || index + 1,
    title: sanitizeText(tool.title || tool.name || 'Outil sans nom'),
    url: tool.url || '#',
    source: tool.source || 'free_for_dev',
    cleanCategory: sanitizeText(tool.category || tool.cleanCategory || 'Général'),
    pricing: tool.pricing || 'Gratuit',
    safeDesc: sanitizeText(rawDesc),
    requiresApi: tool.requiresApi || false,
    cheatSheet: tool.cheatSheet || '',
    appType: tool.appType || 'Web',
  };
});

// Statistiques générales
const totalCount = enrichedTools.length;
const freeDevTools = enrichedTools.filter((t: any) => t.source === 'free_for_dev');
const osintTools = enrichedTools.filter((t: any) => t.source === 'awesome_osint');

const freeDevCount = freeDevTools.length;
const osintCount = osintTools.length;
const categoriesCount = new Set(enrichedTools.map((t: any) => t.cleanCategory)).size;

const freeDevPct = Math.round((freeDevCount / totalCount) * 100) || 0;
const osintPct = Math.round((osintCount / totalCount) * 100) || 0;

// Listes distinctes de catégories pour les menus déroulants
const freeDevCategories = [...new Set(freeDevTools.map((t: any) => t.cleanCategory))].sort();
const osintCategories = [...new Set(osintTools.map((t: any) => t.cleanCategory))].sort();
---

<!DOCTYPE html>
<html lang="fr" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dev & OSINT Vault</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
  </head>
  <body class="bg-[#090d16] text-slate-100 min-h-screen font-sans antialiased selection:bg-blue-500 selection:text-white">

    <!-- NAVBAR SUPÉRIEURE AVEC MENUS DÉROULANTS -->
    <header class="w-full border-b border-slate-800/80 bg-[#090d16]/90 backdrop-blur-md sticky top-0 z-40">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between gap-4">
        
        <!-- LOGO -->
        <a href="/" class="flex items-center gap-2 font-bold text-xl text-white tracking-tight">
          <span class="text-amber-500 text-2xl">⚡</span>
          <span>Vault<span class="text-cyan-400">.dev</span></span>
        </a>

        <!-- NAVIGATION CENTRALE -->
        <nav class="hidden md:flex items-center gap-6 text-sm font-medium text-slate-300">
          <button data-source="ALL" data-cat="ALL" class="nav-filter-btn hover:text-white transition">
            Tout afficher
          </button>

          <!-- MENU DÉROULANT FREE DEV -->
          <div class="relative group">
            <button data-source="free_for_dev" data-cat="ALL" class="nav-filter-btn flex items-center gap-1.5 hover:text-white transition py-2">
              <span class="w-2 h-2 rounded-full bg-emerald-400 inline-block"></span>
              Free Dev <span class="text-xs opacity-60">▾</span>
            </button>
            <div class="absolute top-full left-0 hidden group-hover:block group-focus-within:block w-64 bg-slate-900 border border-slate-800 rounded-xl shadow-2xl p-2 z-50 max-h-80 overflow-y-auto">
              <button data-source="free_for_dev" data-cat="ALL" class="nav-filter-btn w-full text-left px-3 py-1.5 rounded-lg text-xs hover:bg-slate-800 text-emerald-400 font-semibold mb-1">
                Tous les outils Free Dev
              </button>
              <div class="border-t border-slate-800 my-1"></div>
              {freeDevCategories.map((cat: string) => (
                <button data-source="free_for_dev" data-cat={cat} class="nav-filter-btn w-full text-left px-3 py-1.5 rounded-lg text-xs hover:bg-slate-800 text-slate-300 transition truncate block">
                  {cat}
                </button>
              ))}
            </div>
          </div>

          <!-- MENU DÉROULANT OSINT -->
          <div class="relative group">
            <button data-source="awesome_osint" data-cat="ALL" class="nav-filter-btn flex items-center gap-1.5 hover:text-white transition py-2">
              <span class="w-2 h-2 rounded-full bg-purple-400 inline-block"></span>
              OSINT <span class="text-xs opacity-60">▾</span>
            </button>
            <div class="absolute top-full left-0 hidden group-hover:block group-focus-within:block w-64 bg-slate-900 border border-slate-800 rounded-xl shadow-2xl p-2 z-50 max-h-80 overflow-y-auto">
              <button data-source="awesome_osint" data-cat="ALL" class="nav-filter-btn w-full text-left px-3 py-1.5 rounded-lg text-xs hover:bg-slate-800 text-purple-400 font-semibold mb-1">
                Tous les outils OSINT
              </button>
              <div class="border-t border-slate-800 my-1"></div>
              {osintCategories.map((cat: string) => (
                <button data-source="awesome_osint" data-cat={cat} class="nav-filter-btn w-full text-left px-3 py-1.5 rounded-lg text-xs hover:bg-slate-800 text-slate-300 transition truncate block">
                  {cat}
                </button>
              ))}
            </div>
          </div>

          <button id="btn-fav-toggle" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-slate-900 border border-slate-800 text-amber-400 hover:bg-slate-800 transition text-xs font-semibold">
            ⭐ Favoris <span id="fav-badge" class="px-1.5 py-0.5 rounded-full bg-amber-500/20 text-amber-300">0</span>
          </button>
        </nav>

        <!-- BOUTONS DROITE -->
        <div class="flex items-center gap-3">
          <button id="btn-surprise-nav" class="px-3 py-2 text-xs font-semibold text-slate-200 bg-slate-800 hover:bg-slate-700 border border-slate-700 rounded-xl transition flex items-center gap-1.5" title="Découvrir un outil au hasard">
            <span>🎲</span> <span class="hidden sm:inline">Surprenez-moi !</span>
          </button>
          <button id="open-suggest-modal" class="px-4 py-2 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-500 rounded-xl shadow-lg shadow-blue-600/30 transition flex items-center gap-2">
            <span>+</span> Suggérer
          </button>
        </div>
      </div>
    </header>

    <!-- MAIN CONTENT -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 pb-16">

      <!-- HERO & STATS -->
      <section class="pt-6 pb-10 text-center max-w-4xl mx-auto">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-white mb-4">
          Dev & OSINT <span class="bg-gradient-to-r from-teal-300 via-cyan-400 to-blue-400 bg-clip-text text-transparent">Vault</span>
        </h1>
        <p class="text-slate-400 text-base sm:text-lg mb-8 max-w-2xl mx-auto">
          Trouvez instantanément les meilleures ressources gratuites pour devs et chercheurs OSINT.
        </p>

        <!-- BARRE DE RECHERCHE -->
        <div class="max-w-2xl mx-auto relative mb-10">
          <input
            type="text"
            id="search-input"
            placeholder="🔍 Rechercher un outil (ex: github, geoloc, cyber)..."
            class="w-full pl-5 pr-16 py-3.5 rounded-2xl bg-slate-900/90 border border-slate-800 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-blue-500/50 focus:border-blue-500 transition shadow-xl text-sm sm:text-base"
          />
          <button id="trigger-palette" class="absolute right-3 top-3 px-2 py-1 text-xs font-mono bg-slate-800 hover:bg-slate-700 text-slate-400 border border-slate-700 rounded-lg transition hidden sm:inline-block cursor-pointer" title="Raccourci de recherche">
            ⌘K
          </button>
        </div>

        <!-- STATISTIQUES -->
        <div class="bg-slate-900/40 border border-slate-800/80 rounded-2xl p-6 shadow-2xl backdrop-blur-sm">
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
            <div class="bg-slate-900/80 border border-slate-800/90 rounded-xl p-4 text-center">
              <div id="counter-num" class="text-3xl font-extrabold text-white mb-1">{totalCount}</div>
              <div class="text-xs font-medium text-slate-400 uppercase tracking-wider">Ressources Total</div>
            </div>
            <div class="bg-emerald-950/20 border border-emerald-900/40 rounded-xl p-4 text-center">
              <div class="text-3xl font-extrabold text-emerald-400 mb-1">{freeDevCount}</div>
              <div class="text-xs font-medium text-emerald-400/80 uppercase tracking-wider">Free Dev</div>
            </div>
            <div class="bg-purple-950/20 border border-purple-900/40 rounded-xl p-4 text-center">
              <div class="text-3xl font-extrabold text-purple-400 mb-1">{osintCount}</div>
              <div class="text-xs font-medium text-purple-400/80 uppercase tracking-wider">OSINT</div>
            </div>
            <div class="bg-slate-900/80 border border-slate-800/90 rounded-xl p-4 text-center">
              <div class="text-3xl font-extrabold text-slate-200 mb-1">{categoriesCount}</div>
              <div class="text-xs font-medium text-slate-400 uppercase tracking-wider">Catégories</div>
            </div>
          </div>

          <!-- BARRE DE RÉPARTITION -->
          <div class="space-y-2">
            <div class="flex justify-between text-xs font-semibold px-1">
              <span class="text-emerald-400">Free Dev ({freeDevPct}%)</span>
              <span class="text-purple-400">OSINT ({osintPct}%)</span>
            </div>
            <div class="h-2 w-full bg-slate-950 rounded-full overflow-hidden flex p-0.5 border border-slate-800">
              <div class="bg-emerald-400 h-full rounded-l-full" style={`width: ${freeDevPct}%`}></div>
              <div class="bg-purple-500 h-full rounded-r-full" style={`width: ${osintPct}%`}></div>
            </div>
          </div>
        </div>
      </section>

      <!-- FILTRES RAPIDES ET TRI -->
      <div class="flex flex-col md:flex-row gap-4 items-start md:items-center justify-between mb-8">
        <div class="flex items-center gap-2 flex-wrap">
          <button data-source="ALL" data-cat="ALL" class="quick-chip active px-3.5 py-1.5 rounded-lg text-xs font-medium bg-slate-800 hover:bg-slate-700 border border-slate-700 text-slate-200 transition">
            Tous les outils
          </button>
          <button data-source="free_for_dev" data-cat="ALL" class="quick-chip px-3.5 py-1.5 rounded-lg text-xs font-medium bg-slate-900 hover:bg-slate-800 border border-slate-800 text-slate-400 transition">
            💻 Free Dev
          </button>
          <button data-source="awesome_osint" data-cat="ALL" class="quick-chip px-3.5 py-1.5 rounded-lg text-xs font-medium bg-slate-900 hover:bg-slate-800 border border-slate-800 text-slate-400 transition">
            🕵️ OSINT
          </button>
          <button id="btn-surprise-hero" class="px-3.5 py-1.5 rounded-lg text-xs font-medium bg-purple-900/30 hover:bg-purple-900/50 border border-purple-700/50 text-purple-300 transition flex items-center gap-1">
            🎲 Surprenez-moi !
          </button>
        </div>

        <div class="flex items-center gap-3 w-full md:w-auto justify-end">
          <select id="sort-select" class="bg-slate-900 border border-slate-800 text-slate-300 text-xs rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
            <option value="default">Tri par défaut</option>
            <option value="az">Nom (A ➔ Z)</option>
            <option value="za">Nom (Z ➔ A)</option>
          </select>
        </div>
      </div>

      <!-- BANDEAU FILTRE ACTIF -->
      <div id="active-filter-indicator" class="hidden mb-6 flex items-center justify-between p-3 bg-blue-950/40 border border-blue-800/40 rounded-xl text-xs text-blue-300">
        <span>Filtre actif : <strong id="filter-name-text"></strong></span>
        <button id="reset-filter-btn" class="underline hover:text-white">Réinitialiser</button>
      </div>

      <!-- GRILLAGE DES CARTES -->
      <div id="tools-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {enrichedTools.map((tool: any) => (
          <div
            class="tool-card group relative flex flex-col justify-between p-5 bg-slate-900/60 hover:bg-slate-900 border border-slate-800/80 hover:border-slate-700 rounded-2xl transition duration-200 shadow-sm hover:shadow-md cursor-pointer"
            data-id={tool.id}
            data-source={tool.source}
            data-cat={tool.cleanCategory}
            data-title={tool.title}
          >
            <div>
              <div class="flex items-start justify-between gap-3 mb-3">
                <span class="text-xs font-mono px-2.5 py-0.5 rounded-full bg-slate-800 text-slate-400 border border-slate-700/50">
                  {tool.cleanCategory}
                </span>
                <div class="flex items-center gap-1">
                  <button class="fav-btn p-1 hover:text-yellow-400 text-slate-600 transition" data-id={tool.id} title="Ajouter aux favoris">
                    ⭐
                  </button>
                  <button class="copy-btn p-1 hover:text-blue-400 text-slate-600 transition" data-url={tool.url} title="Copier le lien">
                    🔗
                  </button>
                </div>
              </div>

              <h3 class="font-semibold text-slate-100 text-base group-hover:text-blue-400 transition mb-2">
                {tool.title}
              </h3>
              <p class="text-xs text-slate-400 line-clamp-2 mb-4 leading-relaxed">
                {tool.safeDesc}
              </p>
            </div>

            <div class="flex items-center justify-between pt-3 border-t border-slate-800/60 text-xs">
              <span class="text-slate-500 font-mono">{tool.pricing}</span>
              <a
                href={tool.url}
                target="_blank"
                rel="noopener noreferrer"
                class="visit-btn px-3 py-1 bg-slate-800 hover:bg-slate-700 text-slate-200 rounded-lg border border-slate-700/60 transition"
              >
                Visiter ↗
              </a>
            </div>
          </div>
        ))}
      </div>
    </main>

    <!-- MODALE DETAILS OUTIL COMPLET -->
    <div id="details-modal" class="fixed inset-0 z-50 bg-slate-950/80 backdrop-blur-md hidden opacity-0 transition-opacity duration-200 flex items-center justify-center p-4">
      <div class="bg-slate-900 border border-slate-800 rounded-2xl max-w-2xl w-full p-6 shadow-2xl relative overflow-hidden">
        <button id="close-details-modal" class="absolute top-4 right-4 text-slate-400 hover:text-white p-2 text-lg">✕</button>
        
        <!-- BADGES INFORMATIFS -->
        <div class="flex items-center gap-2 mb-3 flex-wrap">
          <span id="modal-source-badge" class="text-xs font-mono px-2.5 py-0.5 bg-blue-500/10 text-blue-400 border border-blue-500/20 rounded-full">--</span>
          <span id="modal-cat-badge" class="text-xs font-mono px-2.5 py-0.5 bg-slate-800 text-slate-300 rounded-full">--</span>
          <span id="modal-pricing-badge" class="text-xs font-mono px-2.5 py-0.5 bg-emerald-950/40 text-emerald-400 border border-emerald-800/40 rounded-full">--</span>
          <span id="modal-apptype-badge" class="text-xs font-mono px-2.5 py-0.5 bg-purple-950/40 text-purple-300 border border-purple-800/40 rounded-full">--</span>
          <span id="modal-api-badge" class="text-xs font-mono px-2.5 py-0.5 bg-amber-950/40 text-amber-300 border border-amber-800/40 rounded-full">--</span>
        </div>

        <h2 id="modal-title" class="text-2xl font-bold text-white mb-3">Titre Outil</h2>
        <p id="modal-desc" class="text-sm text-slate-300 leading-relaxed mb-6">Description détaillée...</p>

        <!-- CHEATSHEET ET COMMANDES -->
        <div id="modal-cheatsheet-container" class="mb-6 bg-slate-950 border border-slate-800 rounded-xl p-4 font-mono text-xs hidden">
          <div class="flex items-center justify-between text-slate-400 mb-2 font-sans font-semibold">
            <span>💡 Commandes & CheatSheet</span>
            <button id="btn-copy-cheatsheet" class="text-blue-400 hover:underline flex items-center gap-1 font-mono text-xs">
              📋 Copier
            </button>
          </div>
          <pre id="modal-cheatsheet" class="text-emerald-400 text-xs whitespace-pre-wrap font-mono overflow-x-auto max-h-40 leading-relaxed"></pre>
        </div>

        <!-- ACTIONS BAS DE MODALE -->
        <div class="flex items-center justify-between pt-4 border-t border-slate-800">
          <button id="modal-fav-toggle" class="text-xs font-semibold px-3.5 py-2 rounded-xl bg-slate-800 hover:bg-slate-700 text-slate-300 transition flex items-center gap-1.5">
            ⭐ <span>Favori</span>
          </button>
          <div class="flex items-center gap-3">
            <button id="modal-copy-link" class="px-4 py-2 bg-slate-800 hover:bg-slate-700 text-slate-200 rounded-xl text-xs font-semibold transition flex items-center gap-1.5">
              🔗 Copier lien
            </button>
            <a id="modal-visit-btn" href="#" target="_blank" rel="noopener noreferrer" class="px-5 py-2 bg-blue-600 hover:bg-blue-500 text-white rounded-xl text-xs font-semibold transition flex items-center gap-1.5 shadow-lg shadow-blue-500/20">
              Visiter ↗
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- MODALE SUGGÉRER -->
    <div id="suggest-modal" class="fixed inset-0 z-50 bg-slate-950/80 backdrop-blur-md hidden opacity-0 transition-opacity duration-200 flex items-center justify-center p-4">
      <div class="bg-slate-900 border border-slate-800 rounded-2xl max-w-lg w-full p-6 shadow-2xl relative">
        <button id="close-modal" class="absolute top-4 right-4 text-slate-400 hover:text-white text-lg p-2">✕</button>
        <h3 class="text-xl font-bold text-white mb-1">🚀 Proposer un outil</h3>
        <p class="text-xs text-slate-400 mb-6">Proposez une ressource. Notre équipe la validera rapidement !</p>

        <form id="suggest-form" class="space-y-4">
          <div>
            <label class="block text-xs font-medium text-slate-300 mb-1">Nom de l'outil *</label>
            <input type="text" id="suggest-name" required class="w-full bg-slate-950 border border-slate-800 rounded-xl px-3.5 py-2 text-sm text-white focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="Ex: Shodan" />
          </div>
          <div>
            <label class="block text-xs font-medium text-slate-300 mb-1">URL du site *</label>
            <input type="url" id="suggest-url" required class="w-full bg-slate-950 border border-slate-800 rounded-xl px-3.5 py-2 text-sm text-white focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="https://..." />
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs font-medium text-slate-300 mb-1">Source *</label>
              <select id="suggest-source" class="w-full bg-slate-950 border border-slate-800 rounded-xl px-3.5 py-2 text-sm text-white focus:outline-none focus:ring-2 focus:ring-blue-500">
                <option value="free_for_dev">Free Dev</option>
                <option value="awesome_osint">OSINT</option>
              </select>
            </div>
            <div>
              <label class="block text-xs font-medium text-slate-300 mb-1">Catégorie *</label>
              <input type="text" id="suggest-cat" required class="w-full bg-slate-950 border border-slate-800 rounded-xl px-3.5 py-2 text-sm text-white focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="Ex: Search Engines" />
            </div>
          </div>
          <div>
            <label class="block text-xs font-medium text-slate-300 mb-1">Description courte</label>
            <textarea id="suggest-desc" rows="3" class="w-full bg-slate-950 border border-slate-800 rounded-xl px-3.5 py-2 text-sm text-white focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="À quoi sert cet outil ?"></textarea>
          </div>
          <button type="submit" class="w-full py-2.5 bg-blue-600 hover:bg-blue-500 text-white rounded-xl text-sm font-semibold transition shadow-lg shadow-blue-500/20">
            Envoyer la suggestion
          </button>
        </form>
      </div>
    </div>

    <!-- TOAST NOTIFICATION -->
    <div id="toast" class="fixed bottom-6 right-6 z-50 flex items-center gap-3 px-4 py-3 bg-slate-900 border border-slate-800 rounded-xl shadow-2xl text-xs font-medium text-white transition-all duration-300 opacity-0 translate-y-10 pointer-events-none">
      <span id="toast-icon" class="text-base">✅</span>
      <span id="toast-message">Action effectuée</span>
    </div>

    <!-- INJECTION SÉCURISÉE DES DONNÉES -->
    <script id="vault-tools-data" type="application/json" set:html={JSON.stringify(enrichedTools)}></script>

    <!-- SCRIPT CLIENT OPTIMISÉ -->
    <script>
      import Fuse from 'fuse.js';

      const rawData = document.getElementById('vault-tools-data')?.textContent || '[]';
      const enrichedTools = JSON.parse(rawData);

      let tools = enrichedTools;
      let selectedSource = 'ALL';
      let selectedCat = 'ALL';
      let showOnlyFavs = false;
      let favorites = JSON.parse(localStorage.getItem('vault_favs') || '[]');
      let displayLimit = 60;
      let filteredToolsCache = [...tools];
      let activeToolForModal = null;

      const fuse = new Fuse(tools, {
        keys: ['title', 'cleanCategory', 'safeDesc', 'pricing', 'appType'],
        threshold: 0.35,
      });

      const searchInput = document.getElementById('search-input') as HTMLInputElement;
      const sortSelect = document.getElementById('sort-select') as HTMLSelectElement;
      const counterNum = document.getElementById('counter-num');
      const favBadge = document.getElementById('fav-badge');
      const toast = document.getElementById('toast');
      const toastIcon = document.getElementById('toast-icon');
      const toastMessage = document.getElementById('toast-message');
      const activeFilterInd = document.getElementById('active-filter-indicator');
      const filterNameText = document.getElementById('filter-name-text');
      const grid = document.getElementById('tools-grid');

      const cardMap = new Map();
      document.querySelectorAll('.tool-card').forEach(card => {
        const id = Number(card.getAttribute('data-id'));
        cardMap.set(id, card);
      });

      function showToast(msg: string, icon = '✅') {
        if (!toast || !toastIcon || !toastMessage) return;
        toastIcon.textContent = icon;
        toastMessage.textContent = msg;
        toast.classList.remove('opacity-0', 'translate-y-10', 'pointer-events-none');
        setTimeout(() => {
          toast.classList.add('opacity-0', 'translate-y-10', 'pointer-events-none');
        }, 2500);
      }

      function updateFavoritesUI() {
        if (favBadge) favBadge.textContent = favorites.length.toString();
        document.querySelectorAll('.fav-btn').forEach(btn => {
          const id = Number(btn.getAttribute('data-id'));
          if (favorites.includes(id)) {
            btn.classList.add('text-yellow-400');
            btn.classList.remove('text-slate-600');
          } else {
            btn.classList.remove('text-yellow-400');
            btn.classList.add('text-slate-600');
          }
        });
      }

      function filterAndDisplay() {
        const query = searchInput ? searchInput.value.trim() : '';
        let matchedTools = [];

        if (query) {
          const results = fuse.search(query);
          matchedTools = results.map(r => r.item);
        } else {
          matchedTools = [...tools];
        }

        matchedTools = matchedTools.filter(t => {
          if (selectedSource !== 'ALL' && t.source !== selectedSource) return false;
          if (selectedCat !== 'ALL' && t.cleanCategory !== selectedCat) return false;
          if (showOnlyFavs && !favorites.includes(t.id)) return false;
          return true;
        });

        const sortVal = sortSelect?.value;
        if (sortVal === 'az') {
          matchedTools.sort((a, b) => a.title.localeCompare(b.title));
        } else if (sortVal === 'za') {
          matchedTools.sort((a, b) => b.title.localeCompare(a.title));
        }

        filteredToolsCache = matchedTools;
        if (counterNum) counterNum.textContent = matchedTools.length.toString();

        requestAnimationFrame(() => {
          const visibleIds = new Set(matchedTools.slice(0, displayLimit).map(t => t.id));

          cardMap.forEach((card, id) => {
            if (visibleIds.has(id)) {
              card.style.display = 'flex';
            } else {
              card.style.display = 'none';
            }
          });
        });

        if (activeFilterInd && filterNameText) {
          if (showOnlyFavs) {
            activeFilterInd.classList.remove('hidden');
            filterNameText.textContent = '⭐ Mes Favoris';
          } else if (selectedCat !== 'ALL') {
            activeFilterInd.classList.remove('hidden');
            filterNameText.textContent = `${selectedSource === 'free_for_dev' ? 'Free Dev' : 'OSINT'} > ${selectedCat}`;
          } else if (selectedSource !== 'ALL') {
            activeFilterInd.classList.remove('hidden');
            filterNameText.textContent = selectedSource === 'free_for_dev' ? 'Free Dev' : 'OSINT';
          } else {
            activeFilterInd.classList.add('hidden');
          }
        }
      }

      // FONCTION "SURPRENEZ-MOI !"
      function triggerRandomTool() {
        const pool = filteredToolsCache.length > 0 ? filteredToolsCache : tools;
        if (!pool || pool.length === 0) return;
        const randomIndex = Math.floor(Math.random() * pool.length);
        const randomTool = pool[randomIndex];
        openToolModal(randomTool.id);
        showToast(`Outil au hasard : ${randomTool.title}`, "🎲");
      }

      document.getElementById('btn-surprise-nav')?.addEventListener('click', triggerRandomTool);
      document.getElementById('btn-surprise-hero')?.addEventListener('click', triggerRandomTool);

      // RACCOURCIS CLAVIER (⌘K pour recherche, Escape pour fermer les modales)
      window.addEventListener('keydown', (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
          e.preventDefault();
          searchInput?.focus();
          searchInput?.select();
        } else if (e.key === 'Escape') {
          closeAllModals();
        }
      });

      document.getElementById('trigger-palette')?.addEventListener('click', () => {
        searchInput?.focus();
        searchInput?.select();
      });

      let searchTimeout: any;
      searchInput?.addEventListener('input', () => {
        clearTimeout(searchTimeout);
        displayLimit = 60;
        searchTimeout = setTimeout(filterAndDisplay, 150);
      });

      sortSelect?.addEventListener('change', () => {
        displayLimit = 60;
        filterAndDisplay();
      });

      document.querySelectorAll('.nav-filter-btn, .quick-chip').forEach(btn => {
        btn.addEventListener('click', () => {
          const sourceAttr = btn.getAttribute('data-source');
          const catAttr = btn.getAttribute('data-cat');

          if (sourceAttr !== null) selectedSource = sourceAttr;
          if (catAttr !== null) selectedCat = catAttr;

          showOnlyFavs = false;
          displayLimit = 60;

          document.querySelectorAll('.quick-chip').forEach(c => c.classList.remove('active', 'border-blue-500'));
          btn.classList.add('active');

          filterAndDisplay();
        });
      });

      document.getElementById('reset-filter-btn')?.addEventListener('click', () => {
        selectedSource = 'ALL';
        selectedCat = 'ALL';
        showOnlyFavs = false;
        if (searchInput) searchInput.value = '';
        filterAndDisplay();
      });

      document.getElementById('btn-fav-toggle')?.addEventListener('click', () => {
        showOnlyFavs = !showOnlyFavs;
        displayLimit = 60;
        filterAndDisplay();
      });

      grid?.addEventListener('click', (e: any) => {
        const target = e.target;
        if (!target) return;
        
        if (target.classList.contains('fav-btn')) {
          e.stopPropagation();
          const id = Number(target.getAttribute('data-id'));
          toggleFavorite(id);
          return;
        }

        if (target.classList.contains('copy-btn')) {
          e.stopPropagation();
          const url = target.getAttribute('data-url') || '';
          navigator.clipboard.writeText(url);
          showToast("Lien copié !", "🔗");
          return;
        }

        const card = target.closest('.tool-card');
        if (card && !target.closest('.visit-btn')) {
          const id = Number(card.getAttribute('data-id'));
          openToolModal(id);
        }
      });

      function toggleFavorite(id: number) {
        if (favorites.includes(id)) {
          favorites = favorites.filter((f: number) => f !== id);
          showToast("Retiré des favoris", "🗑️");
        } else {
          favorites.push(id);
          showToast("Ajouté aux favoris !", "⭐");
        }
        localStorage.setItem('vault_favs', JSON.stringify(favorites));
        updateFavoritesUI();
        if (showOnlyFavs) filterAndDisplay();
      }

      // MODALE DE DETAILS
      const detailsModal = document.getElementById('details-modal');
      const cheatsheetContainer = document.getElementById('modal-cheatsheet-container');
      const cheatsheetText = document.getElementById('modal-cheatsheet');

      function openToolModal(id: number) {
        const tool = tools.find((t: any) => t.id === id);
        if (!tool || !detailsModal) return;

        activeToolForModal = tool;

        // Informations
        (document.getElementById('modal-title') as HTMLElement).textContent = tool.title;
        (document.getElementById('modal-desc') as HTMLElement).textContent = tool.safeDesc;
        
        // Badges
        (document.getElementById('modal-source-badge') as HTMLElement).textContent = tool.source === 'free_for_dev' ? 'Free Dev' : 'OSINT';
        (document.getElementById('modal-cat-badge') as HTMLElement).textContent = tool.cleanCategory;
        (document.getElementById('modal-pricing-badge') as HTMLElement).textContent = tool.pricing || 'Gratuit';
        (document.getElementById('modal-apptype-badge') as HTMLElement).textContent = `App: ${tool.appType || 'Web'}`;
        (document.getElementById('modal-api-badge') as HTMLElement).textContent = tool.requiresApi ? '🔑 API Requise' : '🔓 Sans API';

        // CheatSheet / Commandes
        if (tool.cheatSheet && tool.cheatSheet.trim().length > 0) {
          cheatsheetContainer?.classList.remove('hidden');
          if (cheatsheetText) cheatsheetText.textContent = tool.cheatSheet;
        } else {
          cheatsheetContainer?.classList.add('hidden');
        }

        // Liens et boutons
        const visitBtn = document.getElementById('modal-visit-btn') as HTMLAnchorElement;
        if (visitBtn) visitBtn.href = tool.url;

        detailsModal.classList.remove('hidden');
        setTimeout(() => detailsModal.classList.remove('opacity-0'), 10);
      }

      function closeAllModals() {
        if (detailsModal && !detailsModal.classList.contains('hidden')) {
          detailsModal.classList.add('opacity-0');
          setTimeout(() => detailsModal.classList.add('hidden'), 200);
        }
        if (suggestModal && !suggestModal.classList.contains('hidden')) {
          suggestModal.classList.add('opacity-0');
          setTimeout(() => suggestModal.classList.add('hidden'), 200);
        }
      }

      document.getElementById('close-details-modal')?.addEventListener('click', closeAllModals);

      document.getElementById('modal-copy-link')?.addEventListener('click', () => {
        if (activeToolForModal?.url) {
          navigator.clipboard.writeText(activeToolForModal.url);
          showToast("Lien copié !", "🔗");
        }
      });

      document.getElementById('modal-fav-toggle')?.addEventListener('click', () => {
        if (activeToolForModal) {
          toggleFavorite(activeToolForModal.id);
        }
      });

      document.getElementById('btn-copy-cheatsheet')?.addEventListener('click', () => {
        if (activeToolForModal?.cheatSheet) {
          navigator.clipboard.writeText(activeToolForModal.cheatSheet);
          showToast("CheatSheet copié dans le presse-papier !", "📋");
        }
      });

      // MODALE SUGGÉRER
      const suggestModal = document.getElementById('suggest-modal');
      const suggestForm = document.getElementById('suggest-form') as HTMLFormElement;

      document.getElementById('open-suggest-modal')?.addEventListener('click', () => {
        suggestModal?.classList.remove('hidden');
        setTimeout(() => suggestModal?.classList.remove('opacity-0'), 10);
      });

      document.getElementById('close-modal')?.addEventListener('click', closeAllModals);

suggestForm?.addEventListener('submit', async (e) => {
  e.preventDefault();

  const payload = {
    name: (document.getElementById('suggest-name') as HTMLInputElement)?.value || '',
    url: (document.getElementById('suggest-url') as HTMLInputElement)?.value || '',
    source: (document.getElementById('suggest-source') as HTMLSelectElement)?.value || 'free_for_dev',
    category: (document.getElementById('suggest-cat') as HTMLInputElement)?.value || '',
    description: (document.getElementById('suggest-desc') as HTMLTextAreaElement)?.value || '',
  };

  try {
    // Envoi direct vers votre endpoint Formspree
    const response = await fetch('https://formspree.io/f/xojgnlky', {
      method: 'POST',
      headers: { 
        'Content-Type': 'application/json',
        'Accept': 'application/json'
      },
      body: JSON.stringify(payload),
    });

    if (response.ok) {
      closeAllModals();
      showToast("Suggestion envoyée avec succès !", "🎉");
      suggestForm.reset();
    } else {
      showToast("Erreur lors de l'envoi", "⚠️");
    }
  } catch {
    showToast("Erreur réseau", "❌");
  }
});

      updateFavoritesUI();
      filterAndDisplay();
    </script>
  </body>
</html>