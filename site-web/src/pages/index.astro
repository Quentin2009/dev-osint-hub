---
import '../styles/global.css';
import toolsData from '../data/tools.json';

// Nettoyage des caractères Markdown parasites
const cleanText = (str) => {
  if (!str) return '';
  return str.replace(/\[↑\]\([^)]+\)/g, '').trim();
};

// Statistiques globales du Vault
const totalTools = toolsData.length;
const freeDevTools = toolsData.filter(i => i.source === 'free_for_dev');
const osintTools = toolsData.filter(i => i.source === 'awesome_osint');

const freeDevCount = freeDevTools.length;
const osintCount = osintTools.length;

// Calcul des pourcentages
const freeDevPercent = Math.round((freeDevCount / totalTools) * 100);
const osintPercent = Math.round((osintCount / totalTools) * 100);

// Catégories uniques
const freeDevCategories = [...new Set(freeDevTools.map(i => cleanText(i.category)))].filter(Boolean).sort();
const osintCategories = [...new Set(osintTools.map(i => cleanText(i.category)))].filter(Boolean).sort();
const allCategoriesCount = [...new Set(toolsData.map(i => cleanText(i.category)))].filter(Boolean).length;
---

<html lang="fr" class="dark">
  <head>
    <meta charset="utf-8" />
    <title>Dev & OSINT Vault</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Répertoire ultime de ressources gratuites pour développeurs et chercheurs OSINT." />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  </head>
  <body class="bg-slate-950 text-slate-100 min-h-screen font-['Inter',sans-serif] antialiased pt-20 selection:bg-blue-500 selection:text-white flex flex-col justify-between">
    
    <!-- Background Gradient -->
    <div class="fixed inset-0 bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(59,130,246,0.15),rgba(255,255,255,0))] pointer-events-none"></div>

    <!-- Notification Toast -->
    <div id="toast" class="fixed bottom-5 left-1/2 -translate-x-1/2 z-50 bg-slate-800 text-white px-5 py-3 rounded-full shadow-2xl font-semibold text-sm transition-all duration-300 opacity-0 translate-y-10 pointer-events-none flex items-center gap-2 border border-slate-700">
      <span id="toast-icon">✅</span> <span id="toast-message">Action réussie !</span>
    </div>

    <!-- BOUTON RETOUR EN HAUT -->
    <button id="back-to-top" class="fixed bottom-8 right-8 z-40 bg-blue-600 text-white p-3.5 rounded-full shadow-lg shadow-blue-900/50 opacity-0 pointer-events-none transition-all duration-300 hover:bg-blue-500 hover:-translate-y-1" title="Retour en haut">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 15l7-7 7 7"></path></svg>
    </button>

    <!-- MODALE SUGGÉRER UN OUTIL -->
    <div id="suggest-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-950/80 backdrop-blur-sm hidden opacity-0 transition-opacity duration-200">
      <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 w-full max-w-lg shadow-2xl relative transform scale-95 transition-transform duration-200" id="modal-container">
        
        <button id="close-modal" class="absolute top-4 right-4 text-slate-400 hover:text-white text-xl transition">✕</button>

        <h2 class="text-xl font-bold text-white mb-1 flex items-center gap-2">
          <span>💡</span> Proposer un outil
        </h2>
        <p class="text-xs text-slate-400 mb-5">
          Connaissez-vous une ressource utile ? Partagez-la via notre API !
        </p>

        <form id="suggest-form" class="space-y-4">
          <div>
            <label class="block text-xs font-semibold text-slate-300 mb-1">Nom de l'outil *</label>
            <input type="text" id="suggest-name" required placeholder="Ex: CyberChef" class="w-full px-3 py-2 rounded-xl bg-slate-950 border border-slate-800 text-sm text-white focus:outline-none focus:border-blue-500 transition" />
          </div>

          <div>
            <label class="block text-xs font-semibold text-slate-300 mb-1">Lien URL *</label>
            <input type="url" id="suggest-url" required placeholder="https://..." class="w-full px-3 py-2 rounded-xl bg-slate-950 border border-slate-800 text-sm text-white focus:outline-none focus:border-blue-500 transition" />
          </div>

          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs font-semibold text-slate-300 mb-1">Source *</label>
              <select id="suggest-source" class="w-full px-3 py-2 rounded-xl bg-slate-950 border border-slate-800 text-sm text-white focus:outline-none focus:border-blue-500 transition">
                <option value="free_for_dev">Free Dev</option>
                <option value="awesome_osint">OSINT</option>
                <option value="autre">Autre</option>
              </select>
            </div>
            <div>
              <label class="block text-xs font-semibold text-slate-300 mb-1">Catégorie *</label>
              <input type="text" id="suggest-cat" required placeholder="Ex: Encryption" class="w-full px-3 py-2 rounded-xl bg-slate-950 border border-slate-800 text-sm text-white focus:outline-none focus:border-blue-500 transition" />
            </div>
          </div>

          <div>
            <label class="block text-xs font-semibold text-slate-300 mb-1">Description courte</label>
            <textarea id="suggest-desc" rows="3" placeholder="Brève explication du service..." class="w-full px-3 py-2 rounded-xl bg-slate-950 border border-slate-800 text-sm text-white focus:outline-none focus:border-blue-500 resize-none transition"></textarea>
          </div>

          <div class="pt-2">
            <button type="submit" id="submit-suggest" class="w-full bg-blue-600 hover:bg-blue-500 text-white font-semibold py-2.5 rounded-xl text-sm transition flex justify-center items-center gap-2">
              <span>🚀</span> Envoyer la suggestion
            </button>
          </div>
        </form>

      </div>
    </div>

    <!-- HEADER / NAVBAR -->
    <header class="fixed top-0 left-0 w-full z-40 bg-slate-900/80 backdrop-blur-md border-b border-slate-800/80 px-4 lg:px-8 py-3">
      <div class="max-w-7xl mx-auto flex items-center justify-between gap-4">
        
        <a href="#" id="btn-reset" class="flex items-center gap-2 text-lg font-extrabold tracking-tight text-white hover:text-blue-400 transition shrink-0">
          <span class="text-2xl">⚡</span>
          <span>Vault<span class="text-blue-500">.dev</span></span>
        </a>

        <!-- Menu Navigation Central -->
        <nav class="hidden md:flex items-center gap-1 text-sm font-medium">
          <button class="nav-filter-btn active px-3 py-1.5 rounded-lg text-slate-300 hover:text-white hover:bg-slate-800 transition" data-source="ALL" data-cat="ALL" data-i18n="navAll">
            Tout afficher
          </button>

          <!-- Dropdown FREE DEV -->
          <div class="relative group">
            <button class="flex items-center gap-1 px-3 py-1.5 rounded-lg text-slate-300 hover:text-white hover:bg-slate-800 transition">
              <span class="w-2 h-2 rounded-full bg-emerald-400"></span> Free Dev
              <svg class="w-3.5 h-3.5 text-slate-400 group-hover:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
            </button>
            <div class="absolute left-0 top-full pt-2 hidden group-hover:block w-64">
              <div class="bg-slate-900 border border-slate-800 rounded-xl shadow-2xl p-2 max-h-80 overflow-y-auto scrollbar-thin">
                <button class="nav-filter-btn w-full text-left px-3 py-1.5 rounded-lg text-xs font-semibold text-emerald-400 hover:bg-emerald-950/50 transition mb-1" data-source="free_for_dev" data-cat="ALL" data-i18n="allFreeDev">Toutes les catégories Free Dev</button>
                <div class="h-px bg-slate-800 my-1"></div>
                {freeDevCategories.map(cat => (
                  <button class="nav-filter-btn w-full text-left px-3 py-1.5 rounded-lg text-xs text-slate-400 hover:text-white hover:bg-slate-800 truncate transition" data-source="free_for_dev" data-cat={cat}>{cat}</button>
                ))}
              </div>
            </div>
          </div>

          <!-- Dropdown OSINT -->
          <div class="relative group">
            <button class="flex items-center gap-1 px-3 py-1.5 rounded-lg text-slate-300 hover:text-white hover:bg-slate-800 transition">
              <span class="w-2 h-2 rounded-full bg-purple-400"></span> OSINT
              <svg class="w-3.5 h-3.5 text-slate-400 group-hover:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
            </button>
            <div class="absolute left-0 top-full pt-2 hidden group-hover:block w-64">
              <div class="bg-slate-900 border border-slate-800 rounded-xl shadow-2xl p-2 max-h-80 overflow-y-auto scrollbar-thin">
                <button class="nav-filter-btn w-full text-left px-3 py-1.5 rounded-lg text-xs font-semibold text-purple-400 hover:bg-purple-950/50 transition mb-1" data-source="awesome_osint" data-cat="ALL" data-i18n="allOsint">Toutes les catégories OSINT</button>
                <div class="h-px bg-slate-800 my-1"></div>
                {osintCategories.map(cat => (
                  <button class="nav-filter-btn w-full text-left px-3 py-1.5 rounded-lg text-xs text-slate-400 hover:text-white hover:bg-slate-800 truncate transition" data-source="awesome_osint" data-cat={cat}>{cat}</button>
                ))}
              </div>
            </div>
          </div>

          <!-- FAVORIS & EXPORT -->
          <div class="flex items-center gap-1 bg-slate-950 border border-slate-800 rounded-xl p-0.5 ml-2">
            <button id="btn-fav-toggle" class="flex items-center gap-1.5 px-3 py-1 rounded-lg text-yellow-400 hover:bg-yellow-400/10 transition">
              <span>⭐</span> <span data-i18n="favOnly">Favoris</span>
              <span id="fav-badge" class="text-[10px] bg-yellow-500/20 text-yellow-300 px-1.5 py-0.5 rounded-full">0</span>
            </button>
            <div class="w-px h-4 bg-slate-800"></div>
            <button id="btn-export-fav" class="flex items-center gap-1 px-2.5 py-1 text-slate-400 hover:text-white transition text-xs font-semibold" title="Exporter les favoris en .txt">
              📥 Exporter
            </button>
          </div>
        </nav>

        <!-- Actions Droite -->
        <div class="flex items-center gap-2 shrink-0">
          <button id="open-suggest-modal" class="hidden sm:flex items-center gap-1.5 bg-blue-600 hover:bg-blue-500 text-white text-xs font-bold px-3 py-2 rounded-xl transition shadow-lg shadow-blue-600/20">
            ➕ Suggérer
          </button>
          <div class="flex items-center bg-slate-950 border border-slate-800 rounded-xl p-1 gap-1">
            <button class="lang-btn active px-2.5 py-1 text-xs font-bold rounded-lg transition" data-lang="fr">FR</button>
            <button class="lang-btn px-2.5 py-1 text-xs font-bold rounded-lg text-slate-400 hover:text-white transition" data-lang="en">EN</button>
          </div>
        </div>

      </div>
    </header>

    <!-- MAIN CONTENT -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 relative z-10 w-full">
      
      <!-- Hero / Recherche -->
      <section class="text-center max-w-3xl mx-auto mb-8">
        <h1 class="text-3xl sm:text-5xl font-extrabold tracking-tight text-white mb-3">
          Dev & OSINT <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-teal-400 to-emerald-400">Vault</span>
        </h1>
        <p class="text-slate-400 text-sm sm:text-base" data-i18n="subtitle">
          Trouvez instantanément les meilleures ressources gratuites pour devs et chercheurs OSINT.
        </p>

        <div class="mt-6 relative max-w-2xl mx-auto">
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-slate-500">🔍</div>
          <input 
            type="text" 
            id="search-input" 
            placeholder="Rechercher un outil (ex: github, geoloc, cyber)..." 
            class="w-full pl-11 pr-4 py-3.5 rounded-2xl bg-slate-900/90 border border-slate-800 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-blue-500/50 focus:border-blue-500 transition shadow-xl"
          />
        </div>
      </section>

      <!-- STATISTIQUES DU VAULT -->
      <section class="max-w-4xl mx-auto mb-10 bg-slate-900/40 border border-slate-800/80 rounded-2xl p-4 sm:p-5 backdrop-blur-sm shadow-xl">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-center mb-4">
          <div class="p-3 bg-slate-950/60 rounded-xl border border-slate-800/60">
            <span class="block text-2xl font-extrabold text-white">{totalTools}</span>
            <span class="text-xs text-slate-400 font-medium">Ressources Total</span>
          </div>
          <div class="p-3 bg-emerald-950/20 rounded-xl border border-emerald-900/30">
            <span class="block text-2xl font-extrabold text-emerald-400">{freeDevCount}</span>
            <span class="text-xs text-emerald-300/80 font-medium">Free Dev</span>
          </div>
          <div class="p-3 bg-purple-950/20 rounded-xl border border-purple-900/30">
            <span class="block text-2xl font-extrabold text-purple-400">{osintCount}</span>
            <span class="text-xs text-purple-300/80 font-medium">OSINT</span>
          </div>
          <div class="p-3 bg-slate-950/60 rounded-xl border border-slate-800/60">
            <span class="block text-2xl font-extrabold text-blue-400">{allCategoriesCount}</span>
            <span class="text-xs text-slate-400 font-medium">Catégories</span>
          </div>
        </div>
        <div>
          <div class="flex justify-between text-[11px] font-bold mb-1.5 px-0.5">
            <span class="text-emerald-400">Free Dev ({freeDevPercent}%)</span>
            <span class="text-purple-400">OSINT ({osintPercent}%)</span>
          </div>
          <div class="w-full h-2.5 bg-slate-950 rounded-full overflow-hidden flex p-0.5 border border-slate-800">
            <div style={`width: ${freeDevPercent}%`} class="h-full bg-emerald-500 rounded-l-full transition-all duration-500"></div>
            <div style={`width: ${osintPercent}%`} class="h-full bg-purple-500 rounded-r-full transition-all duration-500"></div>
          </div>
        </div>
      </section>

      <!-- Barre de contrôle (Filtres, Tri et Compteur) -->
      <div class="flex flex-wrap justify-between items-center mb-6 px-1 gap-4 bg-slate-900/50 p-3 rounded-xl border border-slate-800">
        <div id="active-filter-indicator" class="text-xs text-blue-400 bg-blue-500/10 border border-blue-500/20 px-3 py-1.5 rounded-lg hidden">
          Filtre : <span id="filter-name-text" class="font-bold"></span>
        </div>
        
        <div class="flex items-center gap-4 ml-auto w-full sm:w-auto justify-between sm:justify-end">
          <!-- TRI SELECTOR -->
          <div class="flex items-center gap-2">
            <label for="sort-select" class="text-xs text-slate-400 font-semibold hidden sm:block">Trier :</label>
            <select id="sort-select" class="bg-slate-950 border border-slate-700 text-slate-300 text-xs rounded-lg px-2 py-1.5 focus:outline-none focus:border-blue-500 transition cursor-pointer">
              <option value="default">Par pertinence</option>
              <option value="az">Alphabétique (A-Z)</option>
              <option value="za">Alphabétique (Z-A)</option>
            </select>
          </div>
          
          <span id="counter" class="text-sm font-medium text-slate-400">
            Affichage de <strong class="text-white">{toolsData.length}</strong> ressources
          </span>
        </div>
      </div>

      <!-- Grille des Cartes -->
      <main>
        <div id="tools-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 flex-wrap">
          {toolsData.map((tool, index) => {
            const cleanedCat = cleanText(tool.category);
            const isFreeDev = tool.source === 'free_for_dev';
            const isOsint = tool.source === 'awesome_osint';
            const safeDesc = tool.description || "Aucune description disponible.";

            return (
              <div 
                class="tool-card group relative bg-slate-900/50 border border-slate-800 hover:border-slate-700 rounded-2xl p-5 transition-all duration-200 flex flex-col justify-between backdrop-blur-sm"
                data-id={index}
                data-title={tool.title} 
                data-desc={safeDesc} 
                data-cat={cleanedCat}
                data-source={tool.source}
                data-url={tool.url}
              >
                <div>
                  <div class="flex items-center justify-between gap-2 mb-3">
                    <span class="text-[11px] font-semibold px-2.5 py-1 rounded-md bg-slate-800 text-slate-300 border border-slate-700/50 truncate max-w-[150px]">
                      {cleanedCat}
                    </span>
                    
                    <div class="flex items-center gap-2">
                      <button class="copy-btn text-slate-500 hover:text-blue-400 transition text-sm" data-url={tool.url} title="Copier le lien">🔗</button>
                      <button class="fav-btn text-slate-600 hover:text-yellow-400 transition text-lg" data-id={index} title="Favori">★</button>
                      <span class={`text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded ${
                        isFreeDev ? 'bg-emerald-950 text-emerald-400 border border-emerald-800/50' : 'bg-purple-950 text-purple-400 border border-purple-800/50'
                      }`}>
                        {isFreeDev ? 'Free-Dev' : 'OSINT'}
                      </span>
                    </div>
                  </div>

                  <!-- Classes .card-title et .card-desc ajoutées pour le surlignage JS -->
                  <h3 class="card-title text-lg font-bold text-white group-hover:text-blue-400 transition-colors mb-2">
                    {tool.title}
                  </h3>
                  
                  <p class="card-desc text-slate-400 text-sm leading-relaxed line-clamp-3 mb-4">
                    {safeDesc}
                  </p>
                </div>

                <a 
                  href={tool.url} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class="inline-flex items-center justify-center gap-2 w-full py-2.5 px-4 rounded-xl bg-slate-800 hover:bg-blue-600 text-slate-200 hover:text-white text-sm font-semibold transition border border-slate-700/50 hover:border-blue-500"
                >
                  <span data-i18n="visitBtn">Visiter le site</span> ↗
                </a>
              </div>
            );
          })}
        </div>

        <div class="text-center mt-10 mb-16">
          <button id="btn-load-more" class="px-8 py-3.5 rounded-2xl bg-slate-900 hover:bg-blue-600 text-white font-semibold border border-slate-800 hover:border-blue-500 transition shadow-xl">
            Charger plus de ressources...
          </button>
        </div>
      </main>

    </div>

    <!-- Script complet Engine & Interactivity -->
    <script>
      import Fuse from 'fuse.js';

      const i18n = {
        fr: {
          subtitle: "Trouvez instantanément les meilleures ressources gratuites pour devs et chercheurs OSINT.",
          searchPlaceholder: "Rechercher un outil (ex: github, geoloc, cyber)...",
          navAll: "Tout afficher",
          allFreeDev: "Toutes les catégories Free Dev",
          allOsint: "Toutes les catégories OSINT",
          favOnly: "Favoris",
          visitBtn: "Visiter le site",
          counterText: (shown, total) => `Affichage de <strong class="text-white">${shown}</strong> sur <strong class="text-white">${total}</strong> ressources`
        },
        en: {
          subtitle: "Instantly find the best free resources for devs and OSINT researchers.",
          searchPlaceholder: "Search for a tool (ex: github, geoloc, cyber)...",
          navAll: "Show All",
          allFreeDev: "All Free Dev categories",
          allOsint: "All OSINT categories",
          favOnly: "Favorites",
          visitBtn: "Visit Site",
          counterText: (shown, total) => `Showing <strong class="text-white">${shown}</strong> of <strong class="text-white">${total}</strong> resources`
        }
      };

      // States
      let currentLang = 'fr';
      let selectedSource = 'ALL';
      let selectedCategory = 'ALL';
      let currentSort = 'default';
      let favOnly = false;
      let favorites = JSON.parse(localStorage.getItem('vault_favs') || '[]');
      
      const pageSize = 30;
      let visibleLimit = pageSize;

      // DOM Elements
      const cards = Array.from(document.querySelectorAll('.tool-card')) as HTMLElement[];
      const input = document.getElementById('search-input') as HTMLInputElement;
      const counter = document.getElementById('counter');
      const favBadge = document.getElementById('fav-badge');
      const sortSelect = document.getElementById('sort-select') as HTMLSelectElement;
      const activeFilterIndicator = document.getElementById('active-filter-indicator');
      const filterNameText = document.getElementById('filter-name-text');
      const loadMoreBtn = document.getElementById('btn-load-more');
      const toast = document.getElementById('toast');
      const toastMessage = document.getElementById('toast-message');
      const toastIcon = document.getElementById('toast-icon');
      const backToTopBtn = document.getElementById('back-to-top');

      // Helper: Toast
      function showToast(msg, isError = false) {
        if (toast && toastMessage && toastIcon) {
          toastMessage.textContent = msg;
          toastIcon.textContent = isError ? "❌" : "✅";
          toast.classList.remove('opacity-0', 'translate-y-10', 'pointer-events-none');
          setTimeout(() => toast.classList.add('opacity-0', 'translate-y-10', 'pointer-events-none'), 3000);
        }
      }

      // Helper: Highlight Words
      function highlightText(element, rawText, queryWords) {
        if (!queryWords || queryWords.length === 0) {
          element.innerHTML = rawText; // Reset normal text
          return;
        }
        // Regex pour trouver les mots sans casser l'HTML, de façon sécurisée
        const regex = new RegExp(`(${queryWords.join('|')})`, 'gi');
        const highlighted = rawText.replace(regex, '<span class="text-yellow-900 bg-yellow-400 px-0.5 rounded font-bold">$&</span>');
        element.innerHTML = highlighted;
      }

      // Bouton Retour en haut
      window.addEventListener('scroll', () => {
        if (window.scrollY > 400) backToTopBtn?.classList.remove('opacity-0', 'pointer-events-none');
        else backToTopBtn?.classList.add('opacity-0', 'pointer-events-none');
      });
      backToTopBtn?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

      // API FORMSPREE (Envoi du formulaire silencieux)
      const suggestForm = document.getElementById('suggest-form') as HTMLFormElement;
      suggestForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const submitBtn = suggestForm.querySelector('button[type="submit"]') as HTMLButtonElement;
        const originalText = submitBtn.innerHTML;
        
        submitBtn.innerHTML = "⏳ Envoi en cours...";
        submitBtn.disabled = true;

        const formData = new FormData();
        formData.append("Titre", (document.getElementById('suggest-name') as HTMLInputElement).value);
        formData.append("URL", (document.getElementById('suggest-url') as HTMLInputElement).value);
        formData.append("Source", (document.getElementById('suggest-source') as HTMLSelectElement).value);
        formData.append("Catégorie", (document.getElementById('suggest-cat') as HTMLInputElement).value);
        formData.append("Description", (document.getElementById('suggest-desc') as HTMLTextAreaElement).value);

        try {
          // ⚠️ IMPORTANT : Remplace cette URL par celle que te donnera formspree.io
          const response = await fetch("https://formspree.io/f/xojgnlky", {
            method: "POST",
            body: formData,
            headers: { 'Accept': 'application/json' }
          });

          if (response.ok) {
            showToast("Suggestion envoyée avec succès !");
            document.getElementById('suggest-modal')?.classList.add('hidden');
            suggestForm.reset();
          } else {
            showToast("Erreur lors de l'envoi du formulaire.", true);
          }
        } catch (error) {
          showToast("Serveur injoignable. Réessayez plus tard.", true);
        } finally {
          submitBtn.innerHTML = originalText;
          submitBtn.disabled = false;
        }
      });

      // Gestion de la modale Suggérer
      document.getElementById('open-suggest-modal')?.addEventListener('click', () => {
        const m = document.getElementById('suggest-modal');
        m?.classList.remove('hidden');
        setTimeout(() => m?.classList.remove('opacity-0'), 10);
      });
      document.getElementById('close-modal')?.addEventListener('click', () => {
        const m = document.getElementById('suggest-modal');
        m?.classList.add('opacity-0');
        setTimeout(() => m?.classList.add('hidden'), 200);
      });

      // Data Prep pour Fuse
      const toolsData = cards.map((card, index) => ({
        index,
        title: card.getAttribute('data-title') || '',
        desc: card.getAttribute('data-desc') || '',
        cat: card.getAttribute('data-cat') || '',
        source: card.getAttribute('data-source') || '',
        url: card.getAttribute('data-url') || ''
      }));

      const fuse = new Fuse(toolsData, {
        keys: ['title', 'desc', 'cat'],
        threshold: 0.3,
        ignoreLocation: true
      });

      // Filter, Sort & Highlight Logic
      function filterTools() {
        const query = input.value.trim();
        const queryWords = query.length > 2 ? query.split(' ').filter(w => w.length > 1) : [];
        let validIndices = toolsData.map(t => t.index);

        if (query) validIndices = fuse.search(query).map(r => r.item.index);
        if (selectedSource !== 'ALL') validIndices = validIndices.filter(idx => toolsData[idx].source === selectedSource);
        if (selectedCategory !== 'ALL') validIndices = validIndices.filter(idx => toolsData[idx].cat === selectedCategory);
        if (favOnly) validIndices = validIndices.filter(idx => favorites.includes(idx.toString()));

        // Tri (Sorting) via Flex/Grid Order CSS
        let sortedIndices = [...validIndices];
        if (currentSort === 'az') {
          sortedIndices.sort((a, b) => toolsData[a].title.localeCompare(toolsData[b].title));
        } else if (currentSort === 'za') {
          sortedIndices.sort((a, b) => toolsData[b].title.localeCompare(toolsData[a].title));
        }

        const totalMatching = sortedIndices.length;
        let displayedCount = 0;

        // Mise à jour visuelle des cartes
        cards.forEach((card, idx) => {
          if (sortedIndices.includes(idx)) {
            displayedCount++;
            
            // On gère l'ordre CSS selon le tri
            card.style.order = sortedIndices.indexOf(idx).toString();

            if (displayedCount <= visibleLimit) {
              card.classList.remove('hidden');
              
              // Highlighting sur le titre et la desc
              const titleEl = card.querySelector('.card-title');
              const descEl = card.querySelector('.card-desc');
              if (titleEl) highlightText(titleEl, card.getAttribute('data-title'), queryWords);
              if (descEl) highlightText(descEl, card.getAttribute('data-desc'), queryWords);

            } else {
              card.classList.add('hidden');
            }
          } else {
            card.classList.add('hidden');
          }
        });

        // Toggle "Charger plus"
        if (loadMoreBtn) {
          if (totalMatching > visibleLimit) loadMoreBtn.classList.remove('hidden');
          else loadMoreBtn.classList.add('hidden');
        }

        if (counter) counter.innerHTML = i18n[currentLang].counterText(Math.min(displayedCount, visibleLimit), totalMatching);

        // Update Indicateur Filtre
        if (selectedCategory !== 'ALL' || selectedSource !== 'ALL' || favOnly) {
          activeFilterIndicator?.classList.remove('hidden');
          let label = favOnly ? "Favoris" : `${selectedSource !== 'ALL' ? (selectedSource === 'free_for_dev' ? 'Free-Dev' : 'OSINT') : ''} ${selectedCategory !== 'ALL' ? '> ' + selectedCategory : ''}`;
          if (filterNameText) filterNameText.textContent = label;
        } else {
          activeFilterIndicator?.classList.add('hidden');
        }
      }

      // Listeners
      input?.addEventListener('input', () => { visibleLimit = pageSize; filterTools(); });
      sortSelect?.addEventListener('change', (e) => { currentSort = (e.target as HTMLSelectElement).value; filterTools(); });
      loadMoreBtn?.addEventListener('click', () => { visibleLimit += pageSize; filterTools(); });

      document.querySelectorAll('.nav-filter-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          favOnly = false;
          visibleLimit = pageSize;
          selectedSource = btn.getAttribute('data-source') || 'ALL';
          selectedCategory = btn.getAttribute('data-cat') || 'ALL';
          filterTools();
        });
      });

      document.getElementById('btn-reset')?.addEventListener('click', (e) => {
        e.preventDefault();
        favOnly = false;
        visibleLimit = pageSize;
        selectedSource = 'ALL';
        selectedCategory = 'ALL';
        currentSort = 'default';
        if (sortSelect) sortSelect.value = 'default';
        input.value = '';
        filterTools();
      });

      // Actions Cartes (Copier & Favoris)
      document.querySelectorAll('.copy-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          navigator.clipboard.writeText(btn.getAttribute('data-url') || '').then(() => showToast("Lien copié dans le presse-papier !"));
        });
      });

      function updateFavIcons() {
        if (favBadge) favBadge.textContent = favorites.length.toString();
        document.querySelectorAll('.fav-btn').forEach(btn => {
          const id = btn.getAttribute('data-id');
          if (favorites.includes(id)) {
            btn.classList.add('text-yellow-400');
            btn.classList.remove('text-slate-600');
          } else {
            btn.classList.remove('text-yellow-400');
            btn.classList.add('text-slate-600');
          }
        });
      }

      document.querySelectorAll('.fav-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const id = btn.getAttribute('data-id');
          if (!id) return;
          if (favorites.includes(id)) favorites = favorites.filter(f => f !== id);
          else favorites.push(id);
          
          localStorage.setItem('vault_favs', JSON.stringify(favorites));
          updateFavIcons();
          if (favOnly) filterTools();
        });
      });

      document.getElementById('btn-fav-toggle')?.addEventListener('click', () => {
        favOnly = !favOnly;
        visibleLimit = pageSize;
        filterTools();
      });

      // Init
      updateFavIcons();
      filterTools();
    </script>
  </body>
</html>