---
import '../styles/global.css';
import toolsData from '../data/tools.json';

// Fonction de nettoyage des catégories OSINT
const cleanCategory = (cat) => {
  if (!cat) return '';
  // Supprime la syntaxe Markdown [↑](#...) et les espaces inutiles
  return cat.replace(/\[↑\]\([^)]+\)/g, '').trim();
};

// Séparation et nettoyage des catégories par source
const freeDevCategories = [...new Set(
  toolsData
    .filter(i => i.source === 'free_for_dev')
    .map(i => cleanCategory(i.category))
)].filter(Boolean).sort();

const osintCategories = [...new Set(
  toolsData
    .filter(i => i.source === 'awesome_osint')
    .map(i => cleanCategory(i.category))
)].filter(Boolean).sort();
---
<html lang="fr" class="dark">
  <head>
    <meta charset="utf-8" />
    <title>Dev & OSINT Vault</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  </head>
  <body class="bg-slate-950 text-slate-100 min-h-screen font-['Inter',sans-serif] antialiased pt-20 selection:bg-blue-500 selection:text-white">
    
    <!-- Background Gradient -->
    <div class="fixed inset-0 bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(59,130,246,0.15),rgba(255,255,255,0))] pointer-events-none"></div>

    <!-- BARRE D'OUTILS PERMANENTE EN HAUT (HEADER / NAVBAR) -->
    <header class="fixed top-0 left-0 w-full z-50 bg-slate-900/80 backdrop-blur-md border-b border-slate-800/80 px-4 lg:px-8 py-3">
      <div class="max-w-7xl mx-auto flex items-center justify-between gap-4">
        
        <!-- Logo / Accueil -->
        <a href="#" id="btn-reset" class="flex items-center gap-2 text-lg font-extrabold tracking-tight text-white hover:text-blue-400 transition shrink-0">
          <span class="text-2xl">⚡</span>
          <span>Vault<span class="text-blue-500">.dev</span></span>
        </a>

        <!-- Menu Navigation Central (Dropdowns) -->
        <nav class="hidden md:flex items-center gap-1 text-sm font-medium">
          
          <!-- Bouton Tout afficher -->
          <button class="nav-filter-btn active px-3 py-1.5 rounded-lg text-slate-300 hover:text-white hover:bg-slate-800 transition" data-source="ALL" data-cat="ALL" data-i18n="navAll">
            Tout afficher
          </button>

          <!-- Dropdown FREE DEV -->
          <div class="relative group">
            <button class="flex items-center gap-1 px-3 py-1.5 rounded-lg text-slate-300 hover:text-white hover:bg-slate-800 transition">
              <span class="w-2 h-2 rounded-full bg-emerald-400"></span>
              Free Dev
              <svg class="w-3.5 h-3.5 text-slate-400 group-hover:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
            </button>
            
            <div class="absolute left-0 top-full pt-2 hidden group-hover:block w-64">
              <div class="bg-slate-900 border border-slate-800 rounded-xl shadow-2xl p-2 max-h-80 overflow-y-auto scrollbar-thin">
                <button class="nav-filter-btn w-full text-left px-3 py-1.5 rounded-lg text-xs font-semibold text-emerald-400 hover:bg-emerald-950/50 transition mb-1" data-source="free_for_dev" data-cat="ALL" data-i18n="allFreeDev">
                  Toutes les catégories Free Dev
                </button>
                <div class="h-px bg-slate-800 my-1"></div>
                {freeDevCategories.map(cat => (
                  <button class="nav-filter-btn w-full text-left px-3 py-1.5 rounded-lg text-xs text-slate-400 hover:text-white hover:bg-slate-800 truncate transition" data-source="free_for_dev" data-cat={cat}>
                    {cat}
                  </button>
                ))}
              </div>
            </div>
          </div>

          <!-- Dropdown OSINT -->
          <div class="relative group">
            <button class="flex items-center gap-1 px-3 py-1.5 rounded-lg text-slate-300 hover:text-white hover:bg-slate-800 transition">
              <span class="w-2 h-2 rounded-full bg-purple-400"></span>
              OSINT
              <svg class="w-3.5 h-3.5 text-slate-400 group-hover:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
            </button>
            
            <div class="absolute left-0 top-full pt-2 hidden group-hover:block w-64">
              <div class="bg-slate-900 border border-slate-800 rounded-xl shadow-2xl p-2 max-h-80 overflow-y-auto scrollbar-thin">
                <button class="nav-filter-btn w-full text-left px-3 py-1.5 rounded-lg text-xs font-semibold text-purple-400 hover:bg-purple-950/50 transition mb-1" data-source="awesome_osint" data-cat="ALL" data-i18n="allOsint">
                  Toutes les catégories OSINT
                </button>
                <div class="h-px bg-slate-800 my-1"></div>
                {osintCategories.map(cat => (
                  <button class="nav-filter-btn w-full text-left px-3 py-1.5 rounded-lg text-xs text-slate-400 hover:text-white hover:bg-slate-800 truncate transition" data-source="awesome_osint" data-cat={cat}>
                    {cat}
                  </button>
                ))}
              </div>
            </div>
          </div>

          <!-- Bouton FAVORIS -->
          <button id="btn-fav-toggle" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-yellow-400 hover:bg-yellow-400/10 transition border border-transparent">
            <span>⭐</span>
            <span data-i18n="favOnly">Favoris</span>
            <span id="fav-badge" class="ml-1 text-[10px] bg-yellow-500/20 text-yellow-300 px-1.5 py-0.5 rounded-full">0</span>
          </button>
        </nav>

        <!-- Sélecteur de Langue (Bout) -->
        <div class="flex items-center bg-slate-950 border border-slate-800 rounded-xl p-1 gap-1 shrink-0">
          <button class="lang-btn active px-2.5 py-1 text-xs font-bold rounded-lg transition" data-lang="fr">FR</button>
          <button class="lang-btn px-2.5 py-1 text-xs font-bold rounded-lg text-slate-400 hover:text-white transition" data-lang="en">EN</button>
          <button class="lang-btn px-2.5 py-1 text-xs font-bold rounded-lg text-slate-400 hover:text-white transition" data-lang="es">ES</button>
        </div>

      </div>
    </header>

    <!-- MAIN CONTENT -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 relative z-10">
      
      <!-- Hero / Recherche -->
      <section class="text-center max-w-3xl mx-auto mb-10">
        <h1 class="text-3xl sm:text-5xl font-extrabold tracking-tight text-white mb-3">
          Dev & OSINT <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-teal-400 to-emerald-400">Vault</span>
        </h1>
        <p class="text-slate-400 text-sm sm:text-base" data-i18n="subtitle">
          Trouvez instantanément les meilleures ressources gratuites pour devs et chercheurs OSINT.
        </p>

        <!-- Barre de recherche -->
        <div class="mt-6 relative max-w-2xl mx-auto">
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-slate-500">
            🔍
          </div>
          <input 
            type="text" 
            id="search-input" 
            placeholder="Rechercher un outil..." 
            class="w-full pl-11 pr-4 py-3.5 rounded-2xl bg-slate-900/90 border border-slate-800 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-blue-500/50 focus:border-blue-500 transition shadow-xl"
          />
        </div>
      </section>

      <!-- Compteur et Filtre actif -->
      <div class="flex flex-wrap justify-between items-center mb-6 px-1 gap-2">
        <div id="active-filter-indicator" class="text-xs text-blue-400 bg-blue-500/10 border border-blue-500/20 px-3 py-1 rounded-full hidden">
          Filtre : <span id="filter-name-text" class="font-bold"></span>
        </div>
        <span id="counter" class="text-sm font-medium text-slate-400 ml-auto">
          Affichage de <strong class="text-white">{toolsData.length}</strong> ressources
        </span>
      </div>

      <!-- Grille des Cartes -->
      <main>
        <div id="tools-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
          {toolsData.map((tool, index) => (
            <div 
              class="tool-card group relative bg-slate-900/50 border border-slate-800 hover:border-slate-700 rounded-2xl p-5 transition-all duration-200 flex flex-col justify-between backdrop-blur-sm"
              data-id={index}
              data-title={tool.title} 
              data-desc={tool.description} 
              data-cat={tool.category}
              data-source={tool.source}
            >
              <div>
                <div class="flex items-center justify-between gap-2 mb-3">
                <!-- C'EST ICI ! -->
            <span class="text-[11px] font-semibold px-2.5 py-1 rounded-md bg-slate-800 text-slate-300 border border-slate-700/50 truncate max-w-[180px]">
              {tool.category.replace(/\[↑\]\([^)]+\)/g, '').trim()}
            </span>                  
                  <div class="flex items-center gap-2">
                    <button class="fav-btn text-slate-600 hover:text-yellow-400 transition text-lg" data-id={index} title="Favori">
                      ★
                    </button>
                    <span class={`text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded ${tool.source === 'free_for_dev' ? 'bg-emerald-950 text-emerald-400 border border-emerald-800/50' : 'bg-purple-950 text-purple-400 border border-purple-800/50'}`}>
                      {tool.source === 'free_for_dev' ? 'Free-Dev' : 'OSINT'}
                    </span>
                  </div>
                </div>

                <h3 class="text-lg font-bold text-white group-hover:text-blue-400 transition-colors mb-2">
                  {tool.title}
                </h3>
                
                <p class="text-slate-400 text-sm leading-relaxed line-clamp-3 mb-4">
                  {tool.description || "Aucune description disponible."}
                </p>
              </div>

              <a 
                href={tool.url} 
                target="_blank" 
                rel="noopener noreferrer" 
                class="inline-flex items-center justify-center gap-2 w-full py-2.5 px-4 rounded-xl bg-slate-800 hover:bg-blue-600 text-slate-200 hover:text-white text-sm font-semibold transition border border-slate-700/50 hover:border-blue-500"
              >
                <span data-i18n="visitBtn">Visiter le site</span> ↗
              </a>
            </div>
          ))}
        </div>
      </main>

    </div>

    <!-- Script complet Engine & Interactivité -->
    <script>
      import Fuse from 'fuse.js';

      const i18n = {
        fr: {
          subtitle: "Trouvez instantanément les meilleures ressources gratuites pour devs et chercheurs OSINT.",
          searchPlaceholder: "Rechercher par nom, mot-clé, outil...",
          navAll: "Tout afficher",
          allFreeDev: "Toutes les catégories Free Dev",
          allOsint: "Toutes les catégories OSINT",
          favOnly: "Favoris",
          visitBtn: "Visiter le site",
          counterText: (count) => `Affichage de <strong class="text-white">${count}</strong> ressources`
        },
        en: {
          subtitle: "Instantly find the best free resources for devs and OSINT researchers.",
          searchPlaceholder: "Search by name, keyword, tool...",
          navAll: "Show All",
          allFreeDev: "All Free Dev categories",
          allOsint: "All OSINT categories",
          favOnly: "Favorites",
          visitBtn: "Visit Site",
          counterText: (count) => `Showing <strong class="text-white">${count}</strong> resources`
        },
        es: {
          subtitle: "Encuentre al instante los mejores recursos gratuitos para desarrolladores e investigadores OSINT.",
          searchPlaceholder: "Buscar por nombre, palabra clave, herramienta...",
          navAll: "Mostrar todo",
          allFreeDev: "Todas las categorías Free Dev",
          allOsint: "Todas las categorías OSINT",
          favOnly: "Favoritos",
          visitBtn: "Visitar sitio",
          counterText: (count) => `Mostrando <strong class="text-white">${count}</strong> recursos`
        }
      };

      // State
      let currentLang = 'fr';
      let selectedSource = 'ALL';
      let selectedCategory = 'ALL';
      let favOnly = false;
      let favorites = JSON.parse(localStorage.getItem('vault_favs') || '[]');

      // DOM
      const cards = Array.from(document.querySelectorAll('.tool-card'));
      const input = document.getElementById('search-input') as HTMLInputElement;
      const counter = document.getElementById('counter');
      const favBadge = document.getElementById('fav-badge');
      const activeFilterIndicator = document.getElementById('active-filter-indicator');
      const filterNameText = document.getElementById('filter-name-text');

      // Fuse Engine
      const toolsData = cards.map((card, index) => ({
        index,
        title: card.getAttribute('data-title') || '',
        desc: card.getAttribute('data-desc') || '',
        cat: card.getAttribute('data-cat') || '',
        source: card.getAttribute('data-source') || ''
      }));

      const fuse = new Fuse(toolsData, {
        keys: ['title', 'desc', 'cat'],
        threshold: 0.3,
        ignoreLocation: true
      });

      // Filter Logic
      function filterTools() {
        const query = input.value.trim();
        let validIndices = toolsData.map(t => t.index);

        if (query) {
          validIndices = fuse.search(query).map(r => r.item.index);
        }

        if (selectedSource !== 'ALL') {
          validIndices = validIndices.filter(idx => toolsData[idx].source === selectedSource);
        }

        if (selectedCategory !== 'ALL') {
          validIndices = validIndices.filter(idx => toolsData[idx].cat === selectedCategory);
        }

        if (favOnly) {
          validIndices = validIndices.filter(idx => favorites.includes(idx.toString()));
        }

        let visibleCount = 0;
        cards.forEach((card, idx) => {
          if (validIndices.includes(idx)) {
            card.classList.remove('hidden');
            visibleCount++;
          } else {
            card.classList.add('hidden');
          }
        });

        if (counter) counter.innerHTML = i18n[currentLang].counterText(visibleCount);

        // Update Indicator
        if (selectedCategory !== 'ALL' || selectedSource !== 'ALL' || favOnly) {
          activeFilterIndicator?.classList.remove('hidden');
          let label = favOnly ? "Favoris" : `${selectedSource !== 'ALL' ? (selectedSource === 'free_for_dev' ? 'Free-Dev' : 'OSINT') : ''} ${selectedCategory !== 'ALL' ? '> ' + selectedCategory : ''}`;
          if (filterNameText) filterNameText.textContent = label;
        } else {
          activeFilterIndicator?.classList.add('hidden');
        }
      }

      // Event Listeners
      input?.addEventListener('input', filterTools);

      document.querySelectorAll('.nav-filter-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          favOnly = false;
          selectedSource = btn.getAttribute('data-source') || 'ALL';
          selectedCategory = btn.getAttribute('data-cat') || 'ALL';
          filterTools();
        });
      });

      document.getElementById('btn-reset')?.addEventListener('click', (e) => {
        e.preventDefault();
        favOnly = false;
        selectedSource = 'ALL';
        selectedCategory = 'ALL';
        input.value = '';
        filterTools();
      });

      // Favorites
      function updateFavIcons() {
        if (favBadge) favBadge.textContent = favorites.length.toString();
        document.querySelectorAll('.fav-btn').forEach(btn => {
          const id = btn.getAttribute('data-id');
          if (favorites.includes(id)) {
            btn.classList.add('text-yellow-400');
            btn.classList.remove('text-slate-600');
          } else {
            btn.classList.remove('text-yellow-400');
            btn.classList.add('text-slate-600');
          }
        });
      }

      document.querySelectorAll('.fav-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const id = btn.getAttribute('data-id');
          if (!id) return;

          if (favorites.includes(id)) {
            favorites = favorites.filter(f => f !== id);
          } else {
            favorites.push(id);
          }

          localStorage.setItem('vault_favs', JSON.stringify(favorites));
          updateFavIcons();
          if (favOnly) filterTools();
        });
      });

      document.getElementById('btn-fav-toggle')?.addEventListener('click', () => {
        favOnly = !favOnly;
        filterTools();
      });

      // i18n Language Switcher
      document.querySelectorAll('.lang-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const lang = btn.getAttribute('data-lang');
          if (!lang || !i18n[lang]) return;

          currentLang = lang;

          document.querySelectorAll('.lang-btn').forEach(b => {
            b.classList.remove('active', 'text-white', 'bg-slate-800');
            b.classList.add('text-slate-400');
          });
          btn.classList.add('active', 'text-white', 'bg-slate-800');
          btn.classList.remove('text-slate-400');

          document.querySelectorAll('[data-i18n]').forEach(el => {
            const key = el.getAttribute('data-i18n');
            if (key && i18n[currentLang][key]) {
              el.textContent = i18n[currentLang][key];
            }
          });

          input.placeholder = i18n[currentLang].searchPlaceholder;
          filterTools();
        });
      });

      // Init
      updateFavIcons();
    </script>
  </body>
</html>