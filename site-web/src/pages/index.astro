      <!-- STATISTIQUES DU VAULT -->
      <section class="max-w-4xl mx-auto mb-10 bg-slate-900/40 border border-slate-800/80 rounded-2xl p-4 sm:p-5 backdrop-blur-sm shadow-xl">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-center mb-4">
          <div class="p-3 bg-slate-950/60 rounded-xl border border-slate-800/60">
            <span class="block text-2xl font-extrabold text-white">{totalTools}</span>
            <span class="text-xs text-slate-400 font-medium">Ressources Total</span>
          </div>
          <div class="p-3 bg-emerald-950/20 rounded-xl border border-emerald-900/30">
            <span class="block text-2xl font-extrabold text-emerald-400">{freeDevCount}</span>
            <span class="text-xs text-emerald-300/80 font-medium">Free Dev</span>
          </div>
          <div class="p-3 bg-purple-950/20 rounded-xl border border-purple-900/30">
            <span class="block text-2xl font-extrabold text-purple-400">{osintCount}</span>
            <span class="text-xs text-purple-300/80 font-medium">OSINT</span>
          </div>
          <div class="p-3 bg-slate-950/60 rounded-xl border border-slate-800/60">
            <span class="block text-2xl font-extrabold text-blue-400">{allCategoriesCount}</span>
            <span class="text-xs text-slate-400 font-medium">Catégories</span>
          </div>
        </div>
        <div>
          <div class="flex justify-between text-[11px] font-bold mb-1.5 px-0.5">
            <span class="text-emerald-400">Free Dev ({freeDevPercent}%)</span>
            <span class="text-purple-400">OSINT ({osintPercent}%)</span>
          </div>
          <div class="w-full h-2.5 bg-slate-950 rounded-full overflow-hidden flex p-0.5 border border-slate-800">
            <div style={`width: ${freeDevPercent}%`} class="h-full bg-emerald-500 rounded-l-full transition-all duration-500"></div>
            <div style={`width: ${osintPercent}%`} class="h-full bg-purple-500 rounded-r-full transition-all duration-500"></div>
          </div>
        </div>
      </section>

      <!-- BARRE DE CONTRÔLE -->
      <div class="flex flex-wrap justify-between items-center mb-6 px-1 gap-4 bg-slate-900/50 p-3 rounded-xl border border-slate-800">
        <div id="active-filter-indicator" class="text-xs text-blue-400 bg-blue-500/10 border border-blue-500/20 px-3 py-1.5 rounded-lg hidden">
          Filtre : <span id="filter-name-text" class="font-bold"></span>
        </div>
        
        <div class="flex items-center gap-3 ml-auto w-full sm:w-auto justify-between sm:justify-end">
          <!-- VUE GRILLE / LISTE -->
          <div class="flex items-center bg-slate-950 border border-slate-800 rounded-lg p-0.5">
            <button id="btn-view-grid" class="p-1.5 rounded-md text-slate-400 hover:text-white transition" title="Vue Grille">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M5 3a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2V5a2 2 0 00-2-2H5zM5 11a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2v-2a2 2 0 00-2-2H5zM11 5a2 2 0 002-2h2a2 2 0 002 2v2a2 2 0 00-2 2h-2a2 2 0 00-2-2V5zM11 13a2 2 0 002-2h2a2 2 0 002 2v2a2 2 0 00-2 2h-2a2 2 0 00-2-2v-2z"></path></svg>
            </button>
            <button id="btn-view-list" class="p-1.5 rounded-md text-slate-400 hover:text-white transition" title="Vue Liste Compacte">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z" clip-rule="evenodd"></path></svg>
            </button>
          </div>

          <!-- TRI -->
          <select id="sort-select" class="bg-slate-950 border border-slate-700 text-slate-300 text-xs rounded-lg px-2 py-1.5 focus:outline-none focus:border-blue-500 transition cursor-pointer">
            <option value="default">Par pertinence</option>
            <option value="az">Alphabétique (A-Z)</option>
            <option value="za">Alphabétique (Z-A)</option>
          </select>
          
          <span id="counter" class="text-sm font-medium text-slate-400">
            Affichage de <strong class="text-white">{enrichedTools.length}</strong> ressources
          </span>
        </div>
      </div>

      <!-- GRILLE DES CARTES -->
      <main>
        <div id="tools-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 transition-all">
          {enrichedTools.map((tool) => {
            const isFreeDev = tool.source === 'free_for_dev';

            return (
              <div 
                class="tool-card group relative bg-slate-900/50 border border-slate-800 hover:border-blue-500/50 rounded-2xl p-5 transition-all duration-200 flex flex-col justify-between backdrop-blur-sm cursor-pointer hover:shadow-xl hover:shadow-blue-500/5"
                data-id={tool.id}
                data-title={tool.title} 
                data-desc={tool.safeDesc} 
                data-cat={tool.cleanCategory}
                data-source={tool.source}
                data-url={tool.url}
              >
                <div>
                  <div class="flex items-center justify-between gap-2 mb-3">
                    <div class="flex items-center gap-1.5 overflow-hidden">
                      <span class="text-[11px] font-semibold px-2.5 py-0.5 rounded-md bg-slate-800 text-slate-300 border border-slate-700/50 truncate max-w-[120px]">
                        {tool.cleanCategory}
                      </span>
                      <span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-slate-950 text-slate-400 border border-slate-800">
                        {tool.pricing}
                      </span>
                    </div>
                    
                    <div class="flex items-center gap-2 shrink-0">
                      <button class="copy-btn text-slate-500 hover:text-blue-400 transition text-sm p-1" data-url={tool.url} title="Copier le lien">🔗</button>
                      <button class="fav-btn text-slate-600 hover:text-yellow-400 transition text-lg p-1" data-id={tool.id} title="Favori">★</button>
                      <span class={`text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded ${
                        isFreeDev ? 'bg-emerald-950 text-emerald-400 border border-emerald-800/50' : 'bg-purple-950 text-purple-400 border border-purple-800/50'
                      }`}>
                        {isFreeDev ? 'Free-Dev' : 'OSINT'}
                      </span>
                    </div>
                  </div>

                  <h3 class="card-title text-lg font-bold text-white group-hover:text-blue-400 transition-colors mb-2 flex items-center justify-between">
                    <span>{tool.title}</span>
                    <span class="text-xs text-slate-500 font-normal group-hover:text-blue-400 transition-colors">Détails ℹ️</span>
                  </h3>
                  
                  <p class="card-desc text-slate-400 text-sm leading-relaxed line-clamp-3 mb-4">
                    {tool.safeDesc}
                  </p>
                </div>

                <a 
                  href={tool.url} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class="visit-btn inline-flex items-center justify-center gap-2 w-full py-2.5 px-4 rounded-xl bg-slate-800 hover:bg-blue-600 text-slate-200 hover:text-white text-sm font-semibold transition border border-slate-700/50 hover:border-blue-500"
                >
                  <span>Visiter le site</span> ↗
                </a>
              </div>
            );
          })}
        </div>

        <div class="text-center mt-10 mb-16">
          <button id="btn-load-more" class="px-8 py-3.5 rounded-2xl bg-slate-900 hover:bg-blue-600 text-white font-semibold border border-slate-800 hover:border-blue-500 transition shadow-xl">
            Charger plus de ressources...
          </button>
        </div>
      </main>

    </div>

    <!-- SCRIPT ENGINE -->
    <script>
      import Fuse from 'fuse.js';

      // Pass tools data to client script
      let currentView = localStorage.getItem('vault_view') || 'grid';
      let selectedSource = 'ALL';
      let selectedCategory = 'ALL';
      let currentSort = 'default';
      let favOnly = false;
      let favorites = JSON.parse(localStorage.getItem('vault_favs') || '[]');
      
      const pageSize = 30;
      let visibleLimit = pageSize;
      let activeDetailToolId = null;

      const cards = Array.from(document.querySelectorAll('.tool-card')) as HTMLElement[];
      const input = document.getElementById('search-input') as HTMLInputElement;
      const counter = document.getElementById('counter');
      const favBadge = document.getElementById('fav-badge');
      const sortSelect = document.getElementById('sort-select') as HTMLSelectElement;
      const activeFilterIndicator = document.getElementById('active-filter-indicator');
      const filterNameText = document.getElementById('filter-name-text');
      const loadMoreBtn = document.getElementById('btn-load-more');
      const toast = document.getElementById('toast');
      const toastMessage = document.getElementById('toast-message');
      const toastIcon = document.getElementById('toast-icon');
      const backToTopBtn = document.getElementById('back-to-top');

      // Modale Détails
      const detailsModal = document.getElementById('details-modal');
      const modalTitle = document.getElementById('modal-title');
      const modalDesc = document.getElementById('modal-desc');
      const modalCatBadge = document.getElementById('modal-cat-badge');
      const modalSourceBadge = document.getElementById('modal-source-badge');
      const modalPricingBadge = document.getElementById('modal-pricing-badge');
      const modalApiBadge = document.getElementById('modal-api-badge');
      const modalCommand = document.getElementById('modal-command');
      const modalCheatsheet = document.getElementById('modal-cheatsheet');
      const modalAlternatives = document.getElementById('modal-alternatives');
      const modalVisitBtn = document.getElementById('modal-visit-btn') as HTMLAnchorElement;
      const modalFavBtn = document.getElementById('modal-fav-btn');

      // Palette de commande
      const commandPalette = document.getElementById('command-palette');
      const paletteInput = document.getElementById('palette-input') as HTMLInputElement;

      // Registration PWA Service Worker
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(() => {});
        });
      }

      function showToast(msg, isError = false) {
        if (toast && toastMessage && toastIcon) {
          toastMessage.textContent = msg;
          toastIcon.textContent = isError ? "❌" : "✅";
          toast.classList.remove('opacity-0', 'translate-y-10', 'pointer-events-none');
          setTimeout(() => toast.classList.add('opacity-0', 'translate-y-10', 'pointer-events-none'), 3000);
        }
      }

      // Vue Grille vs Liste
      const viewGridBtn = document.getElementById('btn-view-grid');
      const viewListBtn = document.getElementById('btn-view-list');

      function setView(view) {
        currentView = view;
        localStorage.setItem('vault_view', view);
        if (view === 'list') {
          document.body.classList.add('view-list');
          viewListBtn?.classList.add('bg-slate-800', 'text-blue-400');
          viewGridBtn?.classList.remove('bg-slate-800', 'text-blue-400');
        } else {
          document.body.classList.remove('view-list');
          viewGridBtn?.classList.add('bg-slate-800', 'text-blue-400');
          viewListBtn?.classList.remove('bg-slate-800', 'text-blue-400');
        }
      }
      viewGridBtn?.addEventListener('click', () => setView('grid'));
      viewListBtn?.addEventListener('click', () => setView('list'));
      setView(currentView);

      // Preparation des données pour Fuse.js
      const toolsData = cards.map((card) => {
        const id = card.getAttribute('data-id') || '0';
        const title = card.getAttribute('data-title') || '';
        const desc = card.getAttribute('data-desc') || '';
        const cat = card.getAttribute('data-cat') || '';
        const source = card.getAttribute('data-source') || '';
        const url = card.getAttribute('data-url') || '';
        const isCli = cat.toLowerCase().includes('cli') || desc.toLowerCase().includes('python');
        const requiresApi = desc.toLowerCase().includes('api key') || desc.toLowerCase().includes('shodan');

        return {
          id,
          index: parseInt(id, 10),
          title,
          desc,
          cat,
          source,
          url,
          pricing: url.includes('github.com') ? 'Open Source' : 'Gratuit',
          requiresApi,
          cheatSheet: isCli ? `${title.toLowerCase()} --help\n${title.toLowerCase()} -u target_user` : `curl -s "${url}"`
        };
      });

      // RACCOURCIS CLAVIER GLOBATUX (Ctrl+K, Esc, /, R)
      document.addEventListener('keydown', (e) => {
        const activeTag = document.activeElement?.tagName.toLowerCase();
        const isInput = activeTag === 'input' || activeTag === 'textarea' || activeTag === 'select';

        // Ctrl+K / Cmd+K
        if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
          e.preventDefault();
          toggleCommandPalette();
          return;
        }

        // Escape -> Fermer tout
        if (e.key === 'Escape') {
          closeAllModals();
          return;
        }

        if (!isInput) {
          // Focus Recherche "/"
          if (e.key === '/') {
            e.preventDefault();
            input?.focus();
          }
          // Randomizer "R"
          if (e.key === 'r' || e.key === 'R') {
            e.preventDefault();
            triggerRandomTool();
          }
        }
      });

      function closeAllModals() {
        [detailsModal, commandPalette, document.getElementById('suggest-modal')].forEach(m => {
          m?.classList.add('opacity-0');
          setTimeout(() => m?.classList.add('hidden'), 150);
        });
      }

      function toggleCommandPalette() {
        if (commandPalette?.classList.contains('hidden')) {
          commandPalette.classList.remove('hidden');
          setTimeout(() => {
            commandPalette.classList.remove('opacity-0');
            paletteInput?.focus();
          }, 10);
        } else {
          commandPalette?.classList.add('opacity-0');
          setTimeout(() => commandPalette?.classList.add('hidden'), 150);
        }
      }

      document.getElementById('trigger-palette')?.addEventListener('click', toggleCommandPalette);

      // Fiche Détaillée
      function openToolDetails(index) {
        const tool = toolsData[index];
        if (!tool) return;

        activeDetailToolId = index.toString();

        if (modalTitle) modalTitle.textContent = tool.title;
        if (modalDesc) modalDesc.textContent = tool.desc;
        if (modalCatBadge) modalCatBadge.textContent = tool.cat;
        
        const isFreeDev = tool.source === 'free_for_dev';
        if (modalSourceBadge) {
          modalSourceBadge.textContent = isFreeDev ? 'Free-Dev' : 'OSINT';
          modalSourceBadge.className = `text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded ${
            isFreeDev ? 'bg-emerald-950 text-emerald-400 border border-emerald-800/50' : 'bg-purple-950 text-purple-400 border border-purple-800/50'
          }`;
        }

        if (modalPricingBadge) modalPricingBadge.textContent = tool.pricing;
        if (modalApiBadge) {
          if (tool.requiresApi) modalApiBadge.classList.remove('hidden');
          else modalApiBadge.classList.add('hidden');
        }

        if (modalVisitBtn) modalVisitBtn.href = tool.url;

        if (modalCommand) {
          const cleanTitle = tool.title.toLowerCase().replace(/[^a-z0-9]/g, '');
          modalCommand.textContent = isFreeDev ? `npm install ${cleanTitle}   # ou pip install ${cleanTitle}` : `docker run --rm -it osint/${cleanTitle}:latest`;
        }

        if (modalCheatsheet) modalCheatsheet.textContent = tool.cheatSheet;

        // Alternatives
        if (modalAlternatives) {
          modalAlternatives.innerHTML = '';
          const alts = toolsData.filter(t => t.cat === tool.cat && t.index !== tool.index).slice(0, 4);
          if (alts.length > 0) {
            alts.forEach(alt => {
              const btn = document.createElement('button');
              btn.className = 'px-3 py-1.5 rounded-xl bg-slate-950 border border-slate-800 hover:border-blue-500 text-xs text-slate-300 hover:text-white transition font-medium';
              btn.textContent = `🔗 ${alt.title}`;
              btn.onclick = () => openToolDetails(alt.index);
              modalAlternatives.appendChild(btn);
            });
          } else {
            modalAlternatives.innerHTML = '<span class="text-xs text-slate-500 italic">Aucune autre alternative.</span>';
          }
        }

        updateModalFavButton();
        detailsModal?.classList.remove('hidden');
        setTimeout(() => detailsModal?.classList.remove('opacity-0'), 10);
      }

      function updateModalFavButton() {
        if (!modalFavBtn || activeDetailToolId === null) return;
        const isFav = favorites.includes(activeDetailToolId);
        modalFavBtn.innerHTML = isFav ? '<span class="text-yellow-400">★</span> En favori' : '<span>★</span> Favori';
        modalFavBtn.className = `flex items-center gap-2 px-4 py-2.5 rounded-xl font-semibold text-xs sm:text-sm transition border ${
          isFav ? 'bg-yellow-500/10 border-yellow-500/30 text-yellow-300' : 'bg-slate-800 border-slate-700 text-slate-200 hover:bg-slate-700'
        }`;
      }

      modalFavBtn?.addEventListener('click', () => {
        if (activeDetailToolId === null) return;
        if (favorites.includes(activeDetailToolId)) favorites = favorites.filter(f => f !== activeDetailToolId);
        else favorites.push(activeDetailToolId);
        localStorage.setItem('vault_favs', JSON.stringify(favorites));
        updateFavIcons();
        updateModalFavButton();
      });

      document.getElementById('btn-copy-command')?.addEventListener('click', () => {
        if (modalCommand?.textContent) {
          navigator.clipboard.writeText(modalCommand.textContent).then(() => showToast("Commande copiée !"));
        }
      });

      document.getElementById('close-details-modal')?.addEventListener('click', closeAllModals);

      cards.forEach((card, index) => {
        card.addEventListener('click', (e) => {
          const target = e.target as HTMLElement;
          if (target.closest('.copy-btn') || target.closest('.fav-btn') || target.closest('.visit-btn')) return;
          openToolDetails(index);
        });
      });

      // Random Tool
      function triggerRandomTool() {
        const visibleCards = cards.filter(c => !c.classList.contains('hidden'));
        const pool = visibleCards.length > 0 ? visibleCards : cards;
        const randomCard = pool[Math.floor(Math.random() * pool.length)];
        if (randomCard) {
          const id = randomCard.getAttribute('data-id');
          if (id) openToolDetails(parseInt(id, 10));
        }
      }
      document.getElementById('btn-random-trigger')?.addEventListener('click', triggerRandomTool);

      // EXPORT & PARTAGE FAVORIS (STACK EXPORTER)
      function exportFavoritesMarkdown() {
        if (favorites.length === 0) {
          showToast("Aucun favori à exporter !", true);
          return;
        }
        const favTools = toolsData.filter(t => favorites.includes(t.id));
        let mdContent = `# ⚡ Mon OSINT & Dev Stack (${favTools.length} outils)\n\nGénéré depuis Vault.dev\n\n`;
        favTools.forEach(t => {
          mdContent += `- [**${t.title}**](${t.url}) - *${t.cat}*: ${t.desc}\n`;
        });

        const blob = new Blob([mdContent], { type: 'text/markdown' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'my-vault-favorites.md';
        a.click();
        URL.revokeObjectURL(url);
        showToast("Exportation Markdown téléchargée !");
      }

      function shareFavoritesLink() {
        if (favorites.length === 0) {
          showToast("Ajoutez des favoris avant de partager !", true);
          return;
        }
        const shareUrl = `${window.location.origin}${window.location.pathname}?favs=${favorites.join(',')}`;
        navigator.clipboard.writeText(shareUrl).then(() => {
          showToast("Lien de votre sélection copié !");
        });
      }

      document.getElementById('btn-export-md')?.addEventListener('click', exportFavoritesMarkdown);
      document.getElementById('btn-share-stack')?.addEventListener('click', shareFavoritesLink);

      // Action depuis palette
      document.querySelectorAll('.palette-item').forEach(item => {
        item.addEventListener('click', () => {
          const action = item.getAttribute('data-action');
          toggleCommandPalette();
          if (action === 'random') triggerRandomTool();
          if (action === 'favs') { favOnly = true; filterTools(); }
          if (action === 'export-md') exportFavoritesMarkdown();
          if (action === 'share-stack') shareFavoritesLink();
        });
      });

      // Lecture des favoris partagés dans l'URL (?favs=1,4,12)
      const urlParams = new URLSearchParams(window.location.search);
      const sharedFavs = urlParams.get('favs');
      if (sharedFavs) {
        const parsedIds = sharedFavs.split(',').filter(Boolean);
        if (parsedIds.length > 0) {
          favorites = [...new Set([...favorites, ...parsedIds])];
          localStorage.setItem('vault_favs', JSON.stringify(favorites));
          favOnly = true;
          showToast(`Chargement de ${parsedIds.length} favoris partagés !`);
        }
      }

      // Engine de Recherche (Fuse.js)
      const fuse = new Fuse(toolsData, {
        keys: ['title', 'desc', 'cat'],
        threshold: 0.3,
        ignoreLocation: true
      });

      function filterTools() {
        const query = input.value.trim();
        let validIndices = toolsData.map(t => t.index);

        if (query) validIndices = fuse.search(query).map(r => r.item.index);
        if (selectedSource !== 'ALL') validIndices = validIndices.filter(idx => toolsData[idx].source === selectedSource);
        if (selectedCategory !== 'ALL') validIndices = validIndices.filter(idx => toolsData[idx].cat === selectedCategory);
        if (favOnly) validIndices = validIndices.filter(idx => favorites.includes(idx.toString()));

        let sortedIndices = [...validIndices];
        if (currentSort === 'az') sortedIndices.sort((a, b) => toolsData[a].title.localeCompare(toolsData[b].title));
        else if (currentSort === 'za') sortedIndices.sort((a, b) => toolsData[b].title.localeCompare(toolsData[a].title));

        const totalMatching = sortedIndices.length;
        let displayedCount = 0;

        cards.forEach((card, idx) => {
          if (sortedIndices.includes(idx)) {
            displayedCount++;
            card.style.order = sortedIndices.indexOf(idx).toString();
            if (displayedCount <= visibleLimit) card.classList.remove('hidden');
            else card.classList.add('hidden');
          } else {
            card.classList.add('hidden');
          }
        });

        if (loadMoreBtn) {
          if (totalMatching > visibleLimit) loadMoreBtn.classList.remove('hidden');
          else loadMoreBtn.classList.add('hidden');
        }

        if (counter) counter.innerHTML = `Affichage de <strong class="text-white">${Math.min(displayedCount, visibleLimit)}</strong> sur <strong class="text-white">${totalMatching}</strong> ressources`;

        if (selectedCategory !== 'ALL' || selectedSource !== 'ALL' || favOnly) {
          activeFilterIndicator?.classList.remove('hidden');
          let label = favOnly ? "Favoris" : `${selectedSource !== 'ALL' ? (selectedSource === 'free_for_dev' ? 'Free-Dev' : 'OSINT') : ''} ${selectedCategory !== 'ALL' ? '> ' + selectedCategory : ''}`;
          if (filterNameText) filterNameText.textContent = label;
        } else {
          activeFilterIndicator?.classList.add('hidden');
        }
      }

      input?.addEventListener('input', () => { visibleLimit = pageSize; filterTools(); });
      sortSelect?.addEventListener('change', (e) => { currentSort = (e.target as HTMLSelectElement).value; filterTools(); });
      loadMoreBtn?.addEventListener('click', () => { visibleLimit += pageSize; filterTools(); });

      document.querySelectorAll('.nav-filter-btn, .quick-chip').forEach(btn => {
        btn.addEventListener('click', () => {
          favOnly = false;
          visibleLimit = pageSize;
          selectedSource = btn.getAttribute('data-source') || 'ALL';
          selectedCategory = btn.getAttribute('data-cat') || 'ALL';
          filterTools();
        });
      });

      document.getElementById('btn-reset')?.addEventListener('click', (e) => {
        e.preventDefault();
        favOnly = false;
        visibleLimit = pageSize;
        selectedSource = 'ALL';
        selectedCategory = 'ALL';
        currentSort = 'default';
        if (sortSelect) sortSelect.value = 'default';
        input.value = '';
        filterTools();
      });

      document.querySelectorAll('.copy-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          navigator.clipboard.writeText(btn.getAttribute('data-url') || '').then(() => showToast("Lien copié !"));
        });
      });

      function updateFavIcons() {
        if (favBadge) favBadge.textContent = favorites.length.toString();
        document.querySelectorAll('.fav-btn').forEach(btn => {
          const id = btn.getAttribute('data-id');
          if (favorites.includes(id)) {
            btn.classList.add('text-yellow-400');
            btn.classList.remove('text-slate-600');
          } else {
            btn.classList.remove('text-yellow-400');
            btn.classList.add('text-slate-600');
          }
        });
      }

      document.querySelectorAll('.fav-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const id = btn.getAttribute('data-id');
          if (!id) return;
          if (favorites.includes(id)) favorites = favorites.filter(f => f !== id);
          else favorites.push(id);
          
          localStorage.setItem('vault_favs', JSON.stringify(favorites));
          updateFavIcons();
          if (favOnly) filterTools();
        });
      });

      document.getElementById('btn-fav-toggle')?.addEventListener('click', () => {
        favOnly = !favOnly;
        visibleLimit = pageSize;
        filterTools();
      });

      window.addEventListener('scroll', () => {
        if (window.scrollY > 400) backToTopBtn?.classList.remove('opacity-0', 'pointer-events-none');
        else backToTopBtn?.classList.add('opacity-0', 'pointer-events-none');
      });
      backToTopBtn?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

      // Formspree Suggestion
      document.getElementById('open-suggest-modal')?.addEventListener('click', () => {
        const m = document.getElementById('suggest-modal');
        m?.classList.remove('hidden');
        setTimeout(() => m?.classList.remove('opacity-0'), 10);
      });
      document.getElementById('close-modal')?.addEventListener('click', closeAllModals);

      updateFavIcons();
      filterTools();
    </script>
  </body>
</html>