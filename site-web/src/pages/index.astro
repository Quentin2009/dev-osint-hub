---
import '../styles/global.css';
import toolsData from '../data/tools.json';

// Nettoyage des caractères Markdown parasites
const cleanText = (str) => {
  if (!str) return '';
  return str.replace(/\[↑\]\([^)]+\)/g, '').trim();
};

// Enrichissement automatique des outils (Tags, Modèle économique, Clé API, Cheat Sheet)
const enrichedTools = toolsData.map((tool, index) => {
  const cat = cleanText(tool.category).toLowerCase();
  const desc = (tool.description || '').toLowerCase();
  const url = (tool.url || '').toLowerCase();
  const title = tool.title || '';

  // Heuristiques de catégorisation technique
  const isCli = cat.includes('cli') || cat.includes('terminal') || desc.includes('command line') || desc.includes('python');
  const isGithub = url.includes('github.com') || url.includes('gitlab.com');
  const requiresApi = desc.includes('api key') || desc.includes('clé api') || desc.includes('token') || desc.includes('shodan');

  // Modèle économique
  let pricing = 'Gratuit';
  if (isGithub) pricing = 'Open Source';
  else if (desc.includes('freemium') || desc.includes('free tier')) pricing = 'Freemium';

  // Type d'application
  let appType = isCli ? 'CLI / Terminal' : 'Web App';

  // Aide-mémoire / Flags CLI générés
  const cleanTitle = title.toLowerCase().replace(/[^a-z0-9]/g, '');
  let cheatSheet = isCli
    ? `${cleanTitle} --help\n${cleanTitle} -u target_user --output json`
    : `curl -s "${tool.url}" | grep "status"`;

  return {
    ...tool,
    id: index,
    cleanCategory: cleanText(tool.category),
    safeDesc: tool.description || "Aucune description disponible.",
    pricing,
    appType,
    requiresApi,
    cheatSheet
  };
});

// Statistiques globales du Vault
const totalTools = enrichedTools.length;
const freeDevTools = enrichedTools.filter(i => i.source === 'free_for_dev');
const osintTools = enrichedTools.filter(i => i.source === 'awesome_osint');

const freeDevCount = freeDevTools.length;
const osintCount = osintTools.length;

// Calcul des pourcentages
const freeDevPercent = Math.round((freeDevCount / totalTools) * 100);
const osintPercent = Math.round((osintCount / totalTools) * 100);

// Catégories uniques
const freeDevCategories = [...new Set(freeDevTools.map(i => i.cleanCategory))].filter(Boolean).sort();
const osintCategories = [...new Set(osintTools.map(i => i.cleanCategory))].filter(Boolean).sort();
const allCategoriesCount = [...new Set(enrichedTools.map(i => i.cleanCategory))].filter(Boolean).length;
