---
import toolsData from '../data/tools.json';

// Extraire la liste unique des catégories
const categories = [...new Set(toolsData.map(item => item.category))].sort();
---

<html lang="fr" class="dark">
  <head>
    <meta charset="utf-8" />
    <title>Dev & OSINT Vault</title>
    <meta name="viewport" content="width=device-width" />
  </head>
  <body class="bg-slate-950 text-slate-100 min-h-screen p-6 font-sans">
    
    <header class="max-w-6xl mx-auto mb-10 text-center">
      <h1 class="text-4xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-emerald-400">
        Dev & OSINT Vault
      </h1>
      <p class="text-slate-400 mt-2">Toutes les ressources gratuites pour devs et chercheurs OSINT, centralisées.</p>
      
      <!-- Barre de recherche -->
      <div class="mt-6 max-w-xl mx-auto">
        <input 
          type="text" 
          id="search-input" 
          placeholder="Rechercher un outil (ex: Shodan, Docker, Mail...)" 
          class="w-full p-4 rounded-xl bg-slate-900 border border-slate-800 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-blue-500 shadow-lg"
        />
      </div>
    </header>

    <main class="max-w-6xl mx-auto">
      <div id="tools-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {toolsData.map((tool) => (
          <div class="tool-card p-5 rounded-xl bg-slate-900/60 border border-slate-800 hover:border-slate-700 transition duration-200 flex flex-col justify-between" data-title={tool.title} data-desc={tool.description} data-cat={tool.category}>
            <div>
              <div class="flex items-center justify-between gap-2 mb-2">
                <span class="text-xs px-2 py-1 rounded bg-blue-950 text-blue-300 font-semibold border border-blue-800/50">
                  {tool.category}
                </span>
                <span class="text-[10px] text-slate-500 uppercase tracking-wider">{tool.source}</span>
              </div>
              <h3 class="text-lg font-bold text-white mb-1">{tool.title}</h3>
              <p class="text-sm text-slate-400 line-clamp-3">{tool.description || "Pas de description disponible."}</p>
            </div>
            <a 
              href={tool.url} 
              target="_blank" 
              rel="noopener noreferrer" 
              class="mt-4 inline-flex items-center justify-center w-full py-2 px-4 rounded-lg bg-slate-800 hover:bg-slate-700 text-slate-200 text-sm font-medium transition"
            >
              Visiter ↗
            </a>
          </div>
        ))}
      </div>
    </main>

    <!-- Script client pour la recherche instantanée -->
    <script>
      import Fuse from 'fuse.js';

      const cards = Array.from(document.querySelectorAll('.tool-card'));
      const input = document.getElementById('search-input');

      const tools = cards.map((card, index) => ({
        index,
        title: card.getAttribute('data-title'),
        desc: card.getAttribute('data-desc'),
        cat: card.getAttribute('data-cat')
      }));

      const fuse = new Fuse(tools, {
        keys: ['title', 'desc', 'cat'],
        threshold: 0.3
      });

      input?.addEventListener('input', (e) => {
        const query = e.target.value.trim();

        if (!query) {
          cards.forEach(card => card.classList.remove('hidden'));
          return;
        }

        const results = fuse.search(query).map(r => r.item.index);
        cards.forEach((card, idx) => {
          if (results.includes(idx)) {
            card.classList.remove('hidden');
          } else {
            card.classList.add('hidden');
          }
        });
      });
    </script>
  </body>
</html>