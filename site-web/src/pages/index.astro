---
import '../styles/global.css';
import toolsData from '../data/tools.json';

// Nettoyage et extraction des catégories uniques
const rawCategories = [...new Set(toolsData.map(item => item.category))].filter(Boolean).sort();
---

<html lang="fr" class="dark">
  <head>
    <meta charset="utf-8" />
    <title>Dev & OSINT Vault</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  </head>
  <body class="bg-slate-950 text-slate-100 min-h-screen font-['Inter',sans-serif] antialiased selection:bg-blue-500 selection:text-white">
    
    <!-- Background Decorator -->
    <div class="fixed inset-0 bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(59,130,246,0.15),rgba(255,255,255,0))] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 relative z-10">
      
      <!-- Top Navigation: Langues & Switch Favoris -->
      <div class="flex justify-between items-center mb-8">
        <button 
          id="btn-fav-filter" 
          class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-slate-900 border border-slate-800 hover:border-slate-700 text-sm font-medium transition text-slate-300"
        >
          <span>⭐</span> <span data-i18n="favOnly">Mes Favoris</span>
        </button>

        <!-- Selector de langue -->
        <div class="flex items-center bg-slate-900 border border-slate-800 rounded-xl p-1 gap-1">
          <button class="lang-btn active px-3 py-1 text-xs font-semibold rounded-lg transition" data-lang="fr">FR</button>
          <button class="lang-btn px-3 py-1 text-xs font-semibold rounded-lg text-slate-400 hover:text-white transition" data-lang="en">EN</button>
          <button class="lang-btn px-3 py-1 text-xs font-semibold rounded-lg text-slate-400 hover:text-white transition" data-lang="es">ES</button>
        </div>
      </div>

      <!-- Header -->
      <header class="text-center max-w-3xl mx-auto mb-10">
        <h1 class="text-4xl sm:text-6xl font-extrabold tracking-tight text-white mb-4">
          Dev & OSINT <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-teal-400 to-emerald-400">Vault</span>
        </h1>
        <p class="text-slate-400 text-base sm:text-lg" data-i18n="subtitle">
          Accédez instantanément à toutes les ressources et outils gratuits pour développeurs et chercheurs OSINT.
        </p>

        <!-- Barre de recherche principale -->
        <div class="mt-8 relative max-w-2xl mx-auto">
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-slate-500">
            🔍
          </div>
          <input 
            type="text" 
            id="search-input" 
            placeholder="Rechercher par nom, mot-clé, outil..." 
            class="w-full pl-11 pr-4 py-4 rounded-2xl bg-slate-900/90 border border-slate-800 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-blue-500/50 focus:border-blue-500 transition shadow-2xl backdrop-blur-xl"
          />
        </div>
      </header>

      <!-- Filtres par Catégories (Badges) -->
      <section class="mb-8">
        <div class="flex items-center gap-2 overflow-x-auto pb-4 scrollbar-none" id="categories-bar">
          <button 
            class="cat-btn active shrink-0 px-4 py-2 rounded-xl text-xs font-semibold bg-blue-600 text-white transition border border-blue-500" 
            data-cat="ALL"
            data-i18n="allCats"
          >
            Toutes les catégories
          </button>
          {rawCategories.map((cat) => (
            <button 
              class="cat-btn shrink-0 px-4 py-2 rounded-xl text-xs font-medium bg-slate-900 text-slate-400 hover:text-white border border-slate-800 hover:border-slate-700 transition" 
              data-cat={cat}
            >
              {cat}
            </button>
          ))}
        </div>
      </section>

      <!-- Informations & Compteur -->
      <div class="flex justify-between items-center mb-6 px-1">
        <span id="counter" class="text-sm font-medium text-slate-400">
          Affichage de <strong class="text-white">{toolsData.length}</strong> ressources
        </span>
      </div>

      <!-- Grille des Cartes -->
      <main>
        <div id="tools-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
          {toolsData.map((tool, index) => (
            <div 
              class="tool-card group relative bg-slate-900/50 border border-slate-800/80 hover:border-slate-700 rounded-2xl p-5 transition-all duration-200 flex flex-col justify-between backdrop-blur-sm"
              data-id={index}
              data-title={tool.title} 
              data-desc={tool.description} 
              data-cat={tool.category}
            >
              <div>
                <div class="flex items-center justify-between gap-2 mb-3">
                  <span class="text-[11px] font-semibold px-2.5 py-1 rounded-md bg-slate-800 text-slate-300 border border-slate-700/50 truncate max-w-[180px]">
                    {tool.category}
                  </span>
                  
                  <div class="flex items-center gap-2">
                    <button class="fav-btn text-slate-600 hover:text-yellow-400 transition" data-id={index} title="Favori">
                      ★
                    </button>
                    <span class={`text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded ${tool.source === 'free_for_dev' ? 'bg-emerald-950 text-emerald-400 border border-emerald-800/50' : 'bg-purple-950 text-purple-400 border border-purple-800/50'}`}>
                      {tool.source === 'free_for_dev' ? 'Free-Dev' : 'OSINT'}
                    </span>
                  </div>
                </div>

                <h3 class="text-lg font-bold text-white group-hover:text-blue-400 transition-colors mb-2">
                  {tool.title}
                </h3>
                
                <p class="text-slate-400 text-sm leading-relaxed line-clamp-3 mb-4">
                  {tool.description || "Aucune description disponible pour cette ressource."}
                </p>
              </div>

              <a 
                href={tool.url} 
                target="_blank" 
                rel="noopener noreferrer" 
                class="inline-flex items-center justify-center gap-2 w-full py-2.5 px-4 rounded-xl bg-slate-800 hover:bg-blue-600 text-slate-200 hover:text-white text-sm font-semibold transition border border-slate-700/50 hover:border-blue-500"
              >
                <span data-i18n="visitBtn">Visiter le site</span> ↗
              </a>
            </div>
          ))}
        </div>
      </main>

    </div>

    <!-- Script complet Engine / Search / Traduction / Favoris -->
    <script>
      import Fuse from 'fuse.js';

      // 1. Dictionnaires de traduction
      const i18n = {
        fr: {
          subtitle: "Accédez instantanément à toutes les ressources et outils gratuits pour développeurs et chercheurs OSINT.",
          searchPlaceholder: "Rechercher par nom, mot-clé, outil...",
          allCats: "Toutes les catégories",
          favOnly: "Mes Favoris",
          visitBtn: "Visiter le site",
          counterText: (count) => `Affichage de <strong class="text-white">${count}</strong> ressources`
        },
        en: {
          subtitle: "Instantly access all free resources and tools for developers and OSINT researchers.",
          searchPlaceholder: "Search by name, keyword, tool...",
          allCats: "All Categories",
          favOnly: "My Favorites",
          visitBtn: "Visit Site",
          counterText: (count) => `Showing <strong class="text-white">${count}</strong> resources`
        },
        es: {
          subtitle: "Acceda al instante a todos los recursos y herramientas gratuitas para desarrolladores e investigadores OSINT.",
          searchPlaceholder: "Buscar por nombre, palabra clave, herramienta...",
          allCats: "Todas las categorías",
          favOnly: "Mis Favoritos",
          visitBtn: "Visitar sitio",
          counterText: (count) => `Mostrando <strong class="text-white">${count}</strong> recursos`
        }
      };

      // 2. État Global
      let currentLang = 'fr';
      let currentCategory = 'ALL';
      let favOnly = false;
      let favorites = JSON.parse(localStorage.getItem('vault_favs') || '[]');

      // Éléments du DOM
      const cards = Array.from(document.querySelectorAll('.tool-card'));
      const input = document.getElementById('search-input') as HTMLInputElement;
      const counter = document.getElementById('counter');
      const catBtns = document.querySelectorAll('.cat-btn');
      const favFilterBtn = document.getElementById('btn-fav-filter');

      // 3. Moteur Fuse.js
      const toolsData = cards.map((card, index) => ({
        index,
        title: card.getAttribute('data-title') || '',
        desc: card.getAttribute('data-desc') || '',
        cat: card.getAttribute('data-cat') || ''
      }));

      const fuse = new Fuse(toolsData, {
        keys: ['title', 'desc', 'cat'],
        threshold: 0.3,
        ignoreLocation: true
      });

      // 4. Fonction de filtrage globale (Combine Recherche + Catégorie + Favoris)
      function filterTools() {
        const query = input.value.trim();
        let validIndices = toolsData.map(t => t.index);

        // A. Filtre par recherche
        if (query) {
          validIndices = fuse.search(query).map(r => r.item.index);
        }

        // B. Filtre par catégorie
        if (currentCategory !== 'ALL') {
          validIndices = validIndices.filter(idx => toolsData[idx].cat === currentCategory);
        }

        // C. Filtre par favoris
        if (favOnly) {
          validIndices = validIndices.filter(idx => favorites.includes(idx.toString()));
        }

        // Masquer/Afficher les cartes
        let visibleCount = 0;
        cards.forEach((card, idx) => {
          if (validIndices.includes(idx)) {
            card.classList.remove('hidden');
            visibleCount++;
          } else {
            card.classList.add('hidden');
          }
        });

        // Mise à jour du compteur
        if (counter) {
          counter.innerHTML = i18n[currentLang].counterText(visibleCount);
        }
      }

      // 5. Gestion de la recherche
      input?.addEventListener('input', filterTools);

      // 6. Gestion des Catégories
      catBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          catBtns.forEach(b => {
            b.classList.remove('bg-blue-600', 'text-white', 'border-blue-500');
            b.classList.add('bg-slate-900', 'text-slate-400', 'border-slate-800');
          });
          btn.classList.remove('bg-slate-900', 'text-slate-400', 'border-slate-800');
          btn.classList.add('bg-blue-600', 'text-white', 'border-blue-500');

          currentCategory = btn.getAttribute('data-cat') || 'ALL';
          filterTools();
        });
      });

      // 7. Gestion des Favoris
      function updateFavIcons() {
        document.querySelectorAll('.fav-btn').forEach(btn => {
          const id = btn.getAttribute('data-id');
          if (favorites.includes(id)) {
            btn.classList.add('text-yellow-400');
            btn.classList.remove('text-slate-600');
          } else {
            btn.classList.remove('text-yellow-400');
            btn.classList.add('text-slate-600');
          }
        });
      }

      document.querySelectorAll('.fav-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const id = btn.getAttribute('data-id');
          if (!id) return;

          if (favorites.includes(id)) {
            favorites = favorites.filter(f => f !== id);
          } else {
            favorites.push(id);
          }

          localStorage.setItem('vault_favs', JSON.stringify(favorites));
          updateFavIcons();
          if (favOnly) filterTools();
        });
      });

      favFilterBtn?.addEventListener('click', () => {
        favOnly = !favOnly;
        favFilterBtn.classList.toggle('border-yellow-500/50');
        favFilterBtn.classList.toggle('bg-yellow-500/10');
        filterTools();
      });

      // 8. System de Traduction
      document.querySelectorAll('.lang-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const lang = btn.getAttribute('data-lang');
          if (!lang || !i18n[lang]) return;

          currentLang = lang;
          
          // Style boutons langue
          document.querySelectorAll('.lang-btn').forEach(b => {
            b.classList.remove('active', 'text-white', 'bg-slate-800');
            b.classList.add('text-slate-400');
          });
          btn.classList.add('active', 'text-white', 'bg-slate-800');
          btn.classList.remove('text-slate-400');

          // Appliquer traductions
          document.querySelectorAll('[data-i18n]').forEach(el => {
            const key = el.getAttribute('data-i18n');
            if (key && i18n[currentLang][key]) {
              el.textContent = i18n[currentLang][key];
            }
          });

          input.placeholder = i18n[currentLang].searchPlaceholder;
          filterTools();
        });
      });

      // Initialisation
      updateFavIcons();
    </script>
  </body>
</html>