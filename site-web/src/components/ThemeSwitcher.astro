<div class="flex items-center gap-2 bg-slate-800/80 p-1.5 rounded-lg border border-slate-700">
  <span class="text-xs text-slate-400 font-medium pl-1">🎨 Thème :</span>
  <select id="theme-select" class="bg-slate-900 text-xs text-slate-200 rounded px-2 py-1 outline-none border border-slate-700 cursor-pointer">
    <option value="slate">Dark Slate</option>
    <option value="cyberpunk">Cyberpunk</option>
    <option value="nord">Nord</option>
  </select>
</div>

<script>
  const select = document.getElementById('theme-select') as HTMLSelectElement;
  
  // Charger le thème sauvegardé
  const savedTheme = localStorage.getItem('vault-theme') || 'slate';
  document.documentElement.setAttribute('data-theme', savedTheme);
  if (select) select.value = savedTheme;

  // Écouter les changements
  select?.addEventListener('change', (e) => {
    const theme = (e.target as HTMLSelectElement).value;
    document.documentElement.setAttribute('data-theme', theme);
    localStorage.setItem('vault-theme', theme);
  });
</script>